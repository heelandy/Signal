// ═══════════════════════════════════════════════════════════════════
// HIGHSTRIKE ORB — OPTIONS  (SPY / QQQ · US RTH only · 0DTE entry, max 4-DTE hold)
// Translates the validated STACK signal (same engine as HIGHSTRIKE_ORB_STACK: HH/HL structure gate +
// VWAP cap + structure stop + ATR trail) into option structures on the RTH opening range:
//   • NAKED BUY  — long call (long bias) / long put (short bias), BUY ONLY, never naked short.
//                  Strike = 1-2 ITM / ATM / 1-2 OTM (input; 1 ITM default = delta that tracks the move).
//   • DEBIT  spread — long the chosen strike, short the strike at TP1 (cheapens entry, caps at target).
//   • CREDIT spread — defined-risk vertical on the OTHER side: short strike at the STRUCTURE STOP
//                  (price has to break the stop to hurt it), long protection 1 width beyond.
//   • EXPIRY — 0DTE for same-day momentum; if holding, the FURTHEST allowed expiry is +4 trading
//                  days (dashboard shows both dates). Exit the moment the underlying crosses the trail.
// SCOPE: SPY + QQQ for now (dashboard warns elsewhere) — expand later. RTH only (options session).
// ⚠️ The validated underlying edge is INTRADAY (EOD-flat). 0DTE = the researched profile. Holding a
//    spread to ≤4 DTE is an options-layer allowance (defined-risk carries the gap), NOT separately
//    backtested — prefer 0DTE on naked longs (theta) and reserve multi-day holds for spreads.
// LIMITATION: Pine has NO options-chain / IV / premium / Greeks access. This outputs STRIKES +
// STRUCTURE + THESIS only — price the contracts at the broker before entering.
// ═══════════════════════════════════════════════════════════════════
//@version=6
indicator("HIGHSTRIKE ORB Options", overlay=true, max_labels_count=100)

// ───────────────────────── INPUTS ─────────────────────────
long_on  = input.bool(true, "LONG signals",  group="Direction", inline="d")
short_on = input.bool(true, "SHORT signals", group="Direction", inline="d")
or_start = input.session("0930-1000", "Opening Range window (ET)", group="ORB")
sess_tz  = input.string("America/New_York", "Timezone", options=["America/New_York","America/Chicago","Europe/London"], group="ORB")
trade_end_hhmm = input.int(1500, "Stop new signals after HHMM (ET)", group="ORB", minval=0, maxval=2359)
brk_buf_atr = input.float(0.10, "Breakout strength (clear OR by x ATR)", group="ORB", step=0.05, minval=0.0)
auto_tf  = input.bool(true, "Auto breakout buffer per TF", group="ORB", tooltip="<=5m -> 0.0, else 0.25 ATR. OFF = manual.")
allow_reentry = input.bool(false, "Allow re-entry (re-arm inside OR)", group="ORB",
            tooltip="OFF = one signal per side per day (validated default). ON = re-arm when price falls back inside the OR; capped by Max entries.")
max_entries  = input.int(2, "Max entries per side / day", group="ORB", minval=1)
brk_confirm  = input.string("Wick / touch (resting stop)", "Breakout fill", group="ORB",
            options=["Candle close beyond level (full body)", "Wick / touch (resting stop)"],
            tooltip="DEFAULT STOP-ENTRY (2026-07 fill-mode study): on the EQUITY surface this file trades (SPY/QQQ), a resting STOP at the level clearly beats waiting for the candle close — QQQ +0.214(fail)->+0.473(pass), SPY +0.553->+0.718. 'Candle close beyond level' = the full-body close-confirm (the STACK/NQ default; on NQ the two are ~tied so it's a preference there, but on equities it costs ~0.16-0.26R). 'Wick / touch' fills intrabar the instant price tags the level (earlier).")
strong_body  = input.float(0.25, "Strong-close: min body / candle range", group="ORB", step=0.05, minval=0.0, maxval=1.0,
            tooltip="Close-confirm only (user rule): the breakout candle must be STRONG — body |close−open| ≥ this fraction of the full range AND the right colour (bullish long / bearish short). Default 0.25 = validated sweet spot (F59b, best on NQ/QQQ; rejects dojis/long-wick rejections). Higher (0.4-0.6) cuts trades + lowers edge. 0 = any close beyond the level.")
wait_ft      = input.bool(true, "Wait for next-candle continuation (2-candle confirm)", group="ORB",
            tooltip="F59c (user rule): don't fire on the breakout candle — WAIT for the NEXT candle to CONTINUE the trend (higher close long / lower close short), then fill. Stops 'fired into a reversal' entries. Validated: improves QQQ/SPY, ~neutral NQ. Default ON, in lockstep with STACK.")
// ───────────────────────── STRUCTURE GATE (stack engine) ─────────────────────────
trend_mode = input.string("Off — plain ORB (F58 default)", "Trend gate", group="Structure gate",
             options=["Off — plain ORB (F58 default)", "Auto (structure <=5m / EMA >=15m)", "Structure (HH/HL)", "EMA trend"],
             tooltip="USER FILL RULE: entries fire only DURING A CLEAR TREND (long = structure UPtrend ≤5m / EMA-up ≥15m; short the mirror). Default ON (Auto), in lockstep with STACK. NOTE F58: the gate doesn't ADD expectancy net of honest fills — it's the entry SETUP (clean-trend breakouts only). 'Off — plain ORB' trades every breakout.")
struct_lb  = input.int(5, "Structure pivot lookback (L=R, manual)", group="Structure gate", minval=2)
auto_lb    = input.bool(true, "Auto structure speed (futures 3 / equity 5)", group="Structure gate", tooltip="Fast-direction study (2026-07): NQ/futures keep the FULL structure edge at lb=3 with MORE + EARLIER breakout entries; QQQ needs lb=5 (SPY/QQQ = equity 5). ON = futures 3 / equity 5. Matches HIGHSTRIKE_ORB_STACK.")
int eff_lb = auto_lb ? (syminfo.type == "futures" ? 3 : 5) : struct_lb
fast_dir   = input.bool(true, "1-MINUTE direction feed (structure at 1m speed on ANY chart TF)", group="Structure gate",
             tooltip="STALENESS FIX (user 2026-07, matches HIGHSTRIKE_ORB_STACK/AUTO): the trend-gate st_state is computed from 1-MINUTE bars via request.security, so every chart timeframe flips direction as fast as the 1m chart (pivots confirm in eff_lb MINUTES, not eff_lb chart bars). Stop anchors stay on the chart-TF swings. No-op on a 1m chart.")
struct_tol = input.float(0.10, "Structure tolerance %", group="Structure gate", step=0.05)
trend_ema_f = input.int(21, "Trend EMA fast (EMA mode)", group="Structure gate", minval=2)
trend_ema_s = input.int(50, "Trend EMA slow (EMA mode)", group="Structure gate", minval=5)
// ───────────────────────── VWAP CAP ─────────────────────────
cap_on = input.bool(false, "VWAP-extension cap", group="VWAP cap", tooltip="F58: the cap HURTS honest fills (removes the late-momentum winners, F57). Default OFF, in lockstep with STACK.")
cap_k  = input.float(2.0, "Cap k (xATR beyond VWAP)", group="VWAP cap", step=0.25, minval=0.5)
// ───────────────────────── REGIME ─────────────────────────
local_adx_min = input.float(20.0, "Local ADX min", group="Regime", step=1)
local_atr_hi  = input.float(2.5,  "Volatile ATR%",  group="Regime", step=0.25)
block_range   = input.bool(false,  "Block RANGE regime", group="Regime")
macro_en       = input.bool(true,  "MACRO filter ON", group="Regime")
macro_standdown= input.bool(true,  "Stand-down vs SPY trend", group="Regime")
spy_sym  = input.symbol("SPY",      "Macro trend ref", group="Regime")
vix_sym  = input.symbol("CBOE:VIX", "Macro vol ref",   group="Regime")
vix_calm = input.float(15.0, "VIX calm",     group="Regime", step=1)
vix_vol  = input.float(25.0, "VIX volatile", group="Regime", step=1)
vix_ext  = input.float(35.0, "VIX extreme",  group="Regime", step=1)
spy_adx_min = input.float(25.0, "Macro ADX min", group="Regime", step=1)
persist_n   = input.int(3, "Regime persistence bars", group="Regime", minval=1)
block_d     = input.bool(true, "Block REGIME D", group="Regime")
block_b_ses = input.string("Off", "Block REGIME B trend", group="Regime",
              options=["Off", "London only", "All sessions"],
              tooltip="F31/F31f: regime B is a validated edge — block it only during London hours (03:00-09:30 ET). This script is RTH-only, so 'London only' never blocks B here (B trades all RTH) — matches STACK/AUTO. 'All sessions' restores the old full block. D stays blocked regardless.")
// ───────────────────────── RISK PLAN (graduated: structure stop + trail) ─────────────────────────
stop_mode = input.string("Structure swing (HH/HL)", "Stop placement", group="Risk plan",
            options=["Structure swing (HH/HL)", "OR edge"],
            tooltip="F25b: stop at the last HH/HL swing ~halves the risk. The credit-spread short strike sits here.")
sl_buf_atr  = input.float(0.3, "Stop buffer beyond anchor x ATR", group="Risk plan", step=0.1)
min_stop_atr= input.float(0.5, "Min stop x ATR", group="Risk plan", step=0.1)
sl_max_atr  = input.float(2.5, "Max stop x ATR (manual)", group="Risk plan", step=0.25)
auto_slmax  = input.bool(true, "Auto max-stop per instrument (equity 1.5 / futures 2.5 ATR)", group="Risk plan", tooltip="Arm-timing graduate: equities take a tight 1.5-ATR max stop; futures keep 2.5 (tight whipsaws them). Matches HIGHSTRIKE_ORB_STACK.")
float eff_sl_max = auto_slmax ? (syminfo.type == "futures" ? 2.5 : 1.5) : sl_max_atr
ormid_bias  = input.bool(true, "OR-mid bias — trade only the OR's closing half", group="Structure gate", tooltip="GRADUATED (2026-07): OR closed UPPER half = day biased LONG (block shorts); lower half = biased SHORT (block longs). Additive (NQ +0.17->+0.29, SPY +0.35->+0.56); dropped counter-bias trades are the losers. Matches HIGHSTRIKE_ORB_STACK.")
// ───────────────────────── ENTRY STANDARD (canonical 2026-07-04 — one entry across STACK/AUTO/OPTIONS/BOT/engine) ─────────────────────────
ctx_gate     = input.bool(true, "Layer 1: Structure + VWAP must align (ARMED)", group="Entry standard",
            tooltip="CANONICAL ENTRY STANDARD (strategy docs 2026-07-04): MARKET CONTEXT arms a side — the swing STRUCTURE state (1m-fed when 'fast dir' is on) AND the session-VWAP side must BOTH point the trade way. 'If Structure and VWAP are not aligned, no trade is allowed.' OFF = old plain-ORB arming. Matches HIGHSTRIKE_ORB_STACK.")
watch_gate   = input.bool(true, "Layer 3: close beyond OR mid activates WATCH", group="Entry standard",
            tooltip="A side may only FILL while WATCHING: a confirmed DIRECTIONAL-BODY close beyond the OR MID toward the side. A confirmed close back across the mid CANCELS the watch (+ cooldown). Matches HIGHSTRIKE_ORB_STACK.")
cooldown_n   = input.int(3, "Cooldown bars after a watch cancel", group="Entry standard", minval=0)
stale_n      = input.int(24, "Stale: max bars in WATCH without a fill (0 = off)", group="Entry standard", minval=0,
            tooltip="RANGE / STALE-SETUP RULE: a watch with no valid fill within this many bars is a RANGE — stand down until the mid is lost and a fresh watch cycle begins. 24 bars = 2h on 5m.")
retest_atr   = input.float(0.5, "Pullback: retest within xATR of the level", group="Entry standard", step=0.25, minval=0.0,
            tooltip="PULLBACK MODE: once price runs more than the chase cap past the OR level without a clean fill, do NOT chase — fills stay blocked until price returns within this many ATR of the level. 0 = off.")
chase_max    = input.float(1.0, "Max chase past level (xATR, 0=off)", group="Entry standard", step=0.25, minval=0.0,
            tooltip="Matches STACK: only fire while the bar touched within this many ATR of the breakout level — enter early but DON'T chase; past the cap the setup waits for the RETEST (pullback mode).")
trail_atr   = input.float(2.0, "Trail x ATR (chandelier — exit signal)", group="Risk plan", step=0.5, minval=0.5,
              tooltip="F27b: exit the option when the UNDERLYING crosses the trail. Spreads can also just run to their strikes.")
tp1_rr      = input.float(1.0, "TP1 R (debit-spread cap strike)", group="Risk plan", step=0.25)
tp2_rr      = input.float(4.0, "TP2 R (display target; exit = trail)", group="Risk plan", step=0.25)
// ───────────────────────── OPTIONS ─────────────────────────
strike_sel  = input.string("1 ITM", "Naked-buy strike", group="Options",
              options=["2 ITM", "1 ITM", "ATM", "1 OTM", "2 OTM"],
              tooltip="1-2 ITM = higher delta, tracks the underlying move (default). 1-2 OTM = cheaper convexity, needs the move to run. The dashboard shows the whole ladder.")
strike_inc  = input.float(1.0, "Strike increment $", group="Options", step=0.5, minval=0.5,
              tooltip="SPY/QQQ trade $1 strikes (0.5 exists near the money on 0DTE).")
spread_w    = input.float(3.0, "Spread width $ (protection / cap leg)", group="Options", step=1.0, minval=1.0)
max_dte     = input.int(4, "Max DTE hold (trading days)", group="Options", minval=0, maxval=10,
              tooltip="0DTE to enter; if holding, never past this expiry. Default 4.")
strat_sel   = input.string("Debit spread", "STRAT row: preferred structure", group="Options",
              options=["Naked buy", "Debit spread", "Credit spread"])
est_on      = input.bool(true, "COST row: rough premium estimate", group="Options",
              tooltip="Pine has NO option-chain access — this is a Black-Scholes APPROXIMATION from the IV input below, for sizing intuition only (marked ~). The real premium is at the broker.")
iv_pct      = input.float(20.0, "IV % for the estimate", group="Options", step=1, minval=1)
est_dte     = input.int(0, "Estimate DTE (0 = 0DTE)", group="Options", minval=0, maxval=10)
show_table  = input.bool(true, "Show options dashboard", group="Options")
show_levels = input.bool(true, "Show OR + level lines", group="Options")
show_line_labels = input.bool(true, "Write ENTRY / STOP / TP on the chart", group="Options")

// ───────────────────────── CORE ─────────────────────────
atr14 = ta.atr(14)
[dip, dim, adxV] = ta.dmi(14, 14)
atr_pct = close > 0 ? atr14 / close * 100.0 : 0.0
emaF = ta.ema(close, trend_ema_f)
emaS = ta.ema(close, trend_ema_s)
bool trend_up   = close > emaS and emaF > emaS
bool trend_down = close < emaS and emaF < emaS
float vwap_c = ta.vwap
int o_now = hour(time, sess_tz) * 60 + minute(time, sess_tz)
bool new_day = ta.change(time("D")) != 0
bool wkday = dayofweek != dayofweek.saturday and dayofweek != dayofweek.sunday
int tf_s = timeframe.in_seconds()
float eff_brk = auto_tf ? (tf_s <= 300 ? 0.0 : 0.25) : brk_buf_atr
int trade_end = (trade_end_hhmm / 100) * 60 + (trade_end_hhmm % 100)
bool sym_ok = syminfo.ticker == "SPY" or syminfo.ticker == "QQQ"

// ───────────────────────── HH/HL STRUCTURE STATE (port of hs_harness.py; pivot_tie='tv' per F28) ─────────────────────────
float ph = ta.pivothigh(high, eff_lb, eff_lb)
float pl = ta.pivotlow(low,  eff_lb, eff_lb)
var float ph_last = na
var float ph_prev = na
var float pl_last = na
var float pl_prev = na
var int   st_state = 0
int st_prev = st_state
if not na(ph)
    if na(ph_last) or math.abs(ph - ph_last) / ph_last * 100.0 >= struct_tol
        ph_prev := ph_last
        ph_last := ph
if not na(pl)
    if na(pl_last) or math.abs(pl - pl_last) / pl_last * 100.0 >= struct_tol
        pl_prev := pl_last
        pl_last := pl
bool s_hh = not na(ph_last) and not na(ph_prev) and ph_last > ph_prev
bool s_lh = not na(ph_last) and not na(ph_prev) and ph_last < ph_prev
bool s_hl = not na(pl_last) and not na(pl_prev) and pl_last > pl_prev
bool s_ll = not na(pl_last) and not na(pl_prev) and pl_last < pl_prev
// GAP-AWARE claim guard (STRUC fix 2026-07): UP only while close >= last swing low; DOWN only
// while close <= last swing high — stale HH/HL pairs from the old leg can no longer re-claim a
// trend the price has already broken (the 'Bullish Trend while price dumped' bug).
if s_hh and s_hl and close >= pl_last
    st_state := 1
else if s_ll and s_lh and close <= ph_last
    st_state := 2
else if (s_hh and s_ll) or (s_hl and s_lh)
    st_state := 3
// GAP-AWARE CHoCH: no crossing bar required — in a fast move the swing reference steps toward
// price via new pivots, so the crossing close[1] test could never fire and the state went stale.
if st_prev == 2 and not na(ph_last) and close > ph_last
    st_state := 0
if st_prev == 1 and not na(pl_last) and close < pl_last
    st_state := 0
// 1-MINUTE DIRECTION FEED (fast_dir — same swing machine, 1m context; lockstep w/ STACK/AUTO)
// COMBINED SLOPE ENGINE (user research 2026-07): S = 0.50*(closeSlope/ATR) + 0.30*(bodyMidSlope/ATR)
// + 0.20*bodyPressure — regression over EVERY candle in the window, body midpoints, recency-weighted
// body pressure. ATR-normalized (~ATRs/bar). |S|>=0.10 directional, >=0.30 strong (tune per TF).
f_slope_comb(int N) =>
    float _sc = ta.linreg(close, N, 0) - ta.linreg(close, N, 1)
    float _mid0 = (open + close) / 2.0
    float _sm = ta.linreg(_mid0, N, 0) - ta.linreg(_mid0, N, 1)
    float _a = ta.atr(14)
    float _num = 0.0
    float _den = 0.0
    for _i = 0 to N - 1
        float _w = 1.0 + (N - 1 - _i) / float(math.max(N - 1, 1))
        float _b = close[_i] - open[_i]
        _num += _w * _b
        _den += _w * math.abs(_b)
    float _bp = _den > 0 ? _num / _den : 0.0
    _a > 0 ? 0.50 * (_sc / _a) + 0.30 * (_sm / _a) + 0.20 * _bp : 0.0
f_struct_1m() =>
    float _ph = ta.pivothigh(high, eff_lb, eff_lb)
    float _pl = ta.pivotlow(low,  eff_lb, eff_lb)
    var float _phL = na
    var float _phP = na
    var float _plL = na
    var float _plP = na
    var int _st = 0
    int _stp = _st
    if not na(_ph)
        if na(_phL) or math.abs(_ph - _phL) / _phL * 100.0 >= struct_tol
            _phP := _phL
            _phL := _ph
    if not na(_pl)
        if na(_plL) or math.abs(_pl - _plL) / _plL * 100.0 >= struct_tol
            _plP := _plL
            _plL := _pl
    bool _hh = not na(_phL) and not na(_phP) and _phL > _phP
    bool _lh = not na(_phL) and not na(_phP) and _phL < _phP
    bool _hl = not na(_plL) and not na(_plP) and _plL > _plP
    bool _ll = not na(_plL) and not na(_plP) and _plL < _plP
    if _hh and _hl and close >= _plL
        _st := 1
    else if _ll and _lh and close <= _phL
        _st := 2
    else if (_hh and _ll) or (_hl and _lh)
        _st := 3
    if _stp == 2 and not na(_phL) and close > _phL
        _st := 0
    if _stp == 1 and not na(_plL) and close < _plL
        _st := 0
    [_st, f_slope_comb(12)]
[st_1m, slope_1m] = request.security(syminfo.tickerid, "1", f_struct_1m(), lookahead=barmerge.lookahead_off)
bool use_fast_dir = fast_dir and tf_s > 60
int st_dir = use_fast_dir ? st_1m : st_state                      // DIRECTION state at 1m speed (stops stay chart-TF)
float slope_dir = use_fast_dir ? slope_1m : f_slope_comb(12)      // combined slope S (1m feed on any TF)
// ENTRY STANDARD Layer 1 — MARKET CONTEXT: Structure (1m-fed) + VWAP aligned arms the side
bool ctx_up = st_dir == 1 and close > vwap_c
bool ctx_dn = st_dir == 2 and close < vwap_c
int dir_slp = slope_dir >= 0.10 ? 1 : slope_dir <= -0.10 ? -1 : 0
bool gate_off   = trend_mode == "Off — plain ORB (F58 default)"                       // F58: plain breakout, no trend filter
bool use_struct = trend_mode == "Structure (HH/HL)" or (trend_mode == "Auto (structure <=5m / EMA >=15m)" and tf_s <= 300)
bool eff_up   = gate_off ? true : use_struct ? (st_dir == 1) : trend_up
bool eff_down = gate_off ? true : use_struct ? (st_dir == 2) : trend_down

// ───────────────────────── MACRO REGIME ─────────────────────────
spy_b() =>
    [_a,_b,sadx] = ta.dmi(14,14)
    [close, ta.ema(close,20), ta.ema(close,50), sadx]
vix_b() => ta.sma(close,5)
[spc, se20, se50, sadx] = request.security(spy_sym, "D", spy_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix5 = request.security(vix_sym, "D", vix_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
bool spy_up = not na(spc) and spc > se20 and se20 > se50
bool spy_dn = not na(spc) and spc < se20 and se20 < se50
bool spy_trend = (spy_up or spy_dn) and not na(sadx) and sadx >= spy_adx_min
string reg_raw = "-"
if not na(vix5)
    reg_raw := vix5 >= vix_ext ? "D" : vix5 >= vix_vol ? "C" : (vix5 < vix_calm and spy_trend) ? "A" : (vix5 < vix_vol and not spy_trend) ? "B" : spy_trend ? "A" : "B"
var int reg_cnt = 0
var string reg_pend = "-"
var string reg_conf = "-"
int need = reg_raw == "D" ? 0 : persist_n
if reg_raw == "D"
    reg_conf := "D"
    reg_pend := "D"
    reg_cnt := need
else if reg_raw == reg_pend
    reg_cnt += 1
    if reg_cnt >= need
        reg_conf := reg_raw
else
    reg_pend := reg_raw
    reg_cnt := 1
string regime = reg_conf != "-" ? reg_conf : reg_raw
// F31f: B-block session-scoped. NOTE: this script's o_now is WALL-CLOCK (hour*60+min), so London hours 03:00-09:30 ET = 180-570 (NOT the 540-930 trade-day numbers used in STACK/AUTO). RTH-only ⇒ London-only never blocks here.
bool b_block_now = block_b_ses == "All sessions" or (block_b_ses == "London only" and o_now >= 180 and o_now < 570)
bool macro_allow = not macro_en or not ((regime == "D" and block_d) or (regime == "B" and b_block_now))
bool macro_long_ok  = not macro_en or not macro_standdown or not spy_dn
bool macro_short_ok = not macro_en or not macro_standdown or not spy_up
int local_regime = atr_pct >= local_atr_hi ? 3 : adxV >= local_adx_min ? 1 : 2
bool local_ok = not block_range or local_regime != 2

// ───────────────────────── OPENING RANGE + LEVELS ─────────────────────────
bool in_or = not na(time(timeframe.period, or_start, sess_tz))
var float or_high = na
var float or_low  = na
var bool  or_set  = false
if new_day
    or_high := na
    or_low  := na
    or_set  := false
if in_or
    or_high := na(or_high) ? high : math.max(or_high, high)
    or_low  := na(or_low)  ? low  : math.min(or_low,  low)
var float or_mid  = na
var bool  or_bull = false
if not in_or and not na(or_high)
    if not or_set
        or_mid  := (or_high + or_low) / 2.0
        or_bull := close > or_mid
    or_set := true
float brk_buf = atr14 * eff_brk
var float Le = na
var float Se = na
var bool  traded_l = false
var bool  traded_s = false
var int   n_l = 0
var int   n_s = 0
// ORB ZONE STATE MACHINE (staleness fix 2026-07, lockstep w/ STACK/AUTO): pending side hard-
// invalidated on a confirmed close beyond the OPPOSITE OR edge / pre-entry stop tag; WATCH below
// (long) / above (short) the OR mid; re-arm only after the breakout edge is RECLAIMED (confirmed).
var bool l_invalid = false
var bool s_invalid = false
var bool l_below_mid = false
var bool s_above_mid = false
// CANONICAL WATCH MACHINE (entry standard 2026-07-04, mirrors HIGHSTRIKE_ORB_STACK): latched watch
// per side + cooldown after a mid cancel + stale/RANGE age + pullback extension (don't chase).
var bool l_watch = false
var bool s_watch = false
var int  l_cd = 0
var int  s_cd = 0
var int  l_wage = 0
var int  s_wage = 0
var bool l_range = false
var bool s_range = false
var bool l_ext = false
var bool s_ext = false
if new_day
    Le := na
    Se := na
    traded_l := false
    traded_s := false
    n_l := 0
    n_s := 0
    l_invalid := false
    s_invalid := false
    l_below_mid := false
    s_above_mid := false
    l_watch := false
    s_watch := false
    l_cd := 0
    s_cd := 0
    l_wage := 0
    s_wage := 0
    l_range := false
    s_range := false
    l_ext := false
    s_ext := false
if or_set and na(Le) and not na(or_high) and not na(or_low)
    Le := or_high + brk_buf
    Se := or_low  - brk_buf
// stop anchor: last HH/HL swing (structure) or the OR edge. Recomputed while ARMED, frozen at fill.
var bool in_long  = false
var bool in_short = false
float anchorL = (stop_mode == "Structure swing (HH/HL)" and not na(pl_last)) ? pl_last : or_low
float anchorS = (stop_mode == "Structure swing (HH/HL)" and not na(ph_last)) ? ph_last : or_high
var float Ls = na
var float Ss = na
if not na(Le) and not in_long
    Ls := math.min(math.max(anchorL - atr14 * sl_buf_atr, Le - atr14 * eff_sl_max), Le - atr14 * min_stop_atr)
if not na(Se) and not in_short
    Ss := math.max(math.min(anchorS + atr14 * sl_buf_atr, Se + atr14 * eff_sl_max), Se + atr14 * min_stop_atr)
float Lt1 = na(Le) or na(Ls) ? na : Le + (Le - Ls) * tp1_rr
float St1 = na(Se) or na(Ss) ? na : Se - (Ss - Se) * tp1_rr
float Lt2 = na(Le) or na(Ls) ? na : Le + (Le - Ls) * tp2_rr
float St2 = na(Se) or na(Ss) ? na : Se - (Ss - Se) * tp2_rr

// ───────────────────────── VWAP CAP + GATES + FIRING ─────────────────────────
float extL = na(Le) ? na : (Le - vwap_c) / atr14
float extS = na(Se) ? na : (vwap_c - Se) / atr14
bool cap_long_ok  = not cap_on or na(extL) or extL <= cap_k
bool cap_short_ok = not cap_on or na(extS) or extS <= cap_k
// ── ORB ZONE STATE UPDATE (confirmed closes only — mirrored long/short) ──
if or_set and barstate.isconfirmed and not na(or_high) and not na(or_low)
    l_below_mid := close < or_mid
    s_above_mid := close > or_mid
    // ── canonical WATCH machine (Layer 3, mirrored long/short — confirmed closes only) ──
    if l_cd > 0
        l_cd -= 1
    if s_cd > 0
        s_cd -= 1
    if l_watch and close < or_mid                     // watch cancelled at the mid -> cooldown
        l_watch := false
        l_ext := false
        l_range := false
        l_cd := cooldown_n
    else if not l_watch and l_cd == 0 and close > or_mid and close > open
        l_watch := true                               // clean directional close beyond the mid
        l_wage := 0
    else if l_watch
        l_wage += 1
        if stale_n > 0 and l_wage > stale_n and not in_long
            l_range := true                           // stale setup -> RANGE (no trade this cycle)
        if not in_long and not traded_l and chase_max > 0 and retest_atr > 0 and not na(Le) and high > Le + atr14 * chase_max
            l_ext := true                             // over-extended pre-fill -> PULLBACK
    if l_ext and not na(Le) and low <= Le + atr14 * retest_atr
        l_ext := false                                // OR-edge retest satisfied
    if s_watch and close > or_mid
        s_watch := false
        s_ext := false
        s_range := false
        s_cd := cooldown_n
    else if not s_watch and s_cd == 0 and close < or_mid and close < open
        s_watch := true
        s_wage := 0
    else if s_watch
        s_wage += 1
        if stale_n > 0 and s_wage > stale_n and not in_short
            s_range := true
        if not in_short and not traded_s and chase_max > 0 and retest_atr > 0 and not na(Se) and low < Se - atr14 * chase_max
            s_ext := true
    if s_ext and not na(Se) and high >= Se - atr14 * retest_atr
        s_ext := false
    if not in_long and (close < or_low or (not na(Ls) and low <= Ls))
        l_invalid := true
    else if l_invalid and close > or_high
        l_invalid := false
    if not in_short and (close > or_high or (not na(Ss) and high >= Ss))
        s_invalid := true
    else if s_invalid and close < or_low
        s_invalid := false
bool window = or_set and wkday and o_now < trade_end and not na(Le)
bool gate_long  = long_on  and eff_up   and (not ctx_gate or ctx_up) and macro_allow and macro_long_ok  and local_ok and (not ormid_bias or or_bull)          // +Layer-1 context
bool gate_short = short_on and eff_down  and (not ctx_gate or ctx_dn) and macro_allow and macro_short_ok and local_ok and (not ormid_bias or or_bull == false)
if allow_reentry and traded_l and not na(or_high) and close < or_high and n_l < max_entries
    traded_l := false
if allow_reentry and traded_s and not na(or_low) and close > or_low and n_s < max_entries
    traded_s := false
bool conf_close = brk_confirm == "Candle close beyond level (full body)"          // F59: full-body STRONG close beyond the level
bool body_strong = (high - low) <= 0 or math.abs(close - open) >= strong_body * (high - low)
bool qual_l = close >= Le and close > open and body_strong
bool qual_s = close <= Se and close < open and body_strong
bool brk_l = conf_close ? (wait_ft ? (qual_l[1] and close > close[1]) : qual_l) : high >= Le   // F59c: fire on the next-candle continuation
bool brk_s = conf_close ? (wait_ft ? (qual_s[1] and close < close[1]) : qual_s) : low  <= Se
bool dir_seq = input.bool(true, "Direction sequence (price pushing the trade way)", group="ORB", tooltip="F61: only fire while close>close[1]>close[2] (long) / mirror (short) — price is actually moving the trade direction. Graduate on the touch fill (NQ +0.151->+0.261R, QQQ +0.448, SPY +0.383), ~neutral on close-confirm. Default ON.")
bool seq_l = not dir_seq or (close > close[1] and close[1] > close[2])
bool seq_s = not dir_seq or (close < close[1] and close[1] < close[2])
// LIVE==BACKTEST (HS-H4 parity w/ STACK): close-confirm signals latch only on the CONFIRMED bar
bool cc_bar_ok = not conf_close or barstate.isconfirmed
// ENTRY STANDARD Layer 3 gate + no-chase guard (matches STACK): fire only while the side's WATCH
// is live (active, no cooldown, not stale, not extended) and the bar touched near the level.
bool watch_ok_l = not watch_gate or (l_watch and l_cd == 0 and not l_range and not l_ext)
bool watch_ok_s = not watch_gate or (s_watch and s_cd == 0 and not s_range and not s_ext)
bool near_l = chase_max <= 0 or (not na(Le) and low  <= Le + atr14 * chase_max)
bool near_s = chase_max <= 0 or (not na(Se) and high >= Se - atr14 * chase_max)
bool sig_l = window and not traded_l and not l_invalid and gate_long  and brk_l and seq_l and watch_ok_l and near_l and cc_bar_ok
bool sig_s = window and not traded_s and not s_invalid and gate_short and brk_s and seq_s and watch_ok_s and near_s and cc_bar_ok
bool long_fire  = sig_l and cap_long_ok
bool short_fire = sig_s and cap_short_ok
bool long_skip  = sig_l and not cap_long_ok
bool short_skip = sig_s and not cap_short_ok
if sig_l
    traded_l := true
    n_l += 1
if sig_s
    traded_s := true
    n_s += 1

// ───────────────────────── IN-TRADE: trail on the underlying = the option EXIT signal ─────────────────────────
var float lstop = na
var float sstop = na
var bool l_t1h = false      // TP1 / TP2 touched (state machine + dashboard tags)
var bool l_t2h = false
var bool s_t1h = false
var bool s_t2h = false
var string stL = "WAIT"     // per-side trade state: WAIT/ARMED/FILLED/NEAR TP1/TP1 HIT/TP2 HIT/STOP HIT
var string stS = "WAIT"
if new_day
    in_long  := false
    in_short := false
    lstop := na
    sstop := na
    l_t1h := false
    l_t2h := false
    s_t1h := false
    s_t2h := false
    stL := "WAIT"
    stS := "WAIT"
if long_fire
    in_long := true
    lstop := Ls
    l_t1h := false
    l_t2h := false
if short_fire
    in_short := true
    sstop := Ss
    s_t1h := false
    s_t2h := false
if in_long
    lstop := math.max(lstop, close - trail_atr * atr14)
    if high >= Lt1
        l_t1h := true
    if high >= Lt2
        l_t2h := true
    stL := l_t2h ? "TP2 HIT" : l_t1h ? "TP1 HIT" : close >= Le + 0.75 * (Lt1 - Le) ? "NEAR TP1" : "FILLED"
    if low <= lstop
        in_long := false
        if not l_t1h
            stL := "STOP HIT"
if in_short
    sstop := math.min(sstop, close + trail_atr * atr14)
    if low <= St1
        s_t1h := true
    if low <= St2
        s_t2h := true
    stS := s_t2h ? "TP2 HIT" : s_t1h ? "TP1 HIT" : close <= Se - 0.75 * (Se - St1) ? "NEAR TP1" : "FILLED"
    if high >= sstop
        in_short := false
        if not s_t1h
            stS := "STOP HIT"
bool exit_l = in_long[1] and not in_long
bool exit_s = in_short[1] and not in_short
bool l_live = (window and not traded_l and not l_invalid and gate_long) or in_long
bool s_live = (window and not traded_s and not s_invalid and gate_short) or in_short
float l_stop_now = in_long ? lstop : Ls
float s_stop_now = in_short ? sstop : Ss
// flat-side state refresh — CANONICAL ordering (entry standard 2026-07-04):
//   WAIT (context off) -> ARMED (Structure+VWAP aligned) -> WATCH (confirmed close beyond OR mid)
//   -> FILL, with COOLDOWN / PULLBACK / RANGE / LOCKED guards. Final states persist once traded.
bool armL = window and not traded_l and not l_invalid and gate_long and cap_long_ok
bool armS = window and not traded_s and not s_invalid and gate_short and cap_short_ok
if not in_long and not traded_l
    stL := l_invalid ? "INVALID" : l_cd > 0 ? "COOLDOWN" : l_range ? "RANGE" : (armL and l_ext) ? "PULLBACK" : (armL and l_watch) ? "WATCH" : armL ? "ARMED" : "WAIT"
if not in_short and not traded_s
    stS := s_invalid ? "INVALID" : s_cd > 0 ? "COOLDOWN" : s_range ? "RANGE" : (armS and s_ext) ? "PULLBACK" : (armS and s_watch) ? "WATCH" : armS ? "ARMED" : "WAIT"
if traded_l and not in_long and n_l >= max_entries
    stL := stL == "STOP HIT" or stL == "TP1 HIT" or stL == "TP2 HIT" ? stL : "LOCKED"
if traded_s and not in_short and n_s >= max_entries
    stS := stS == "STOP HIT" or stS == "TP1 HIT" or stS == "TP2 HIT" ? stS : "LOCKED"
// state colors (user legend): WAIT gray · ARMED yellow · WATCH orange · PULLBACK purple · COOLDOWN silver ·
// RANGE dim gray · LOCKED dark gray · FILLED blue · NEAR TP1 lt-green · TP1 green · TP2 dk-green · STOP red · INVALID dark red
f_stc(s) => s == "WAIT" ? color.gray : s == "WATCH" ? color.orange : s == "INVALID" ? color.rgb(139, 0, 0) :
     s == "ARMED" ? color.yellow : s == "FILLED" ? color.rgb(41, 121, 255) :
     s == "PULLBACK" ? color.rgb(187, 134, 252) : s == "COOLDOWN" ? color.silver :
     s == "RANGE" ? color.new(color.gray, 30) : s == "LOCKED" ? color.rgb(90, 90, 90) :
     s == "NEAR TP1" ? color.rgb(144, 238, 144) : s == "TP1 HIT" ? color.green : s == "TP2 HIT" ? color.rgb(0, 102, 0) : color.red

// ───────────────────────── OPTIONS TRANSLATION (1-2 ITM/OTM · 0-4 DTE · buy-only + verticals) ─────────────────────────
f_round(p) => math.round(p / strike_inc) * strike_inc
f_floor(p) => math.floor(p / strike_inc) * strike_inc
f_ceil(p)  => math.ceil(p / strike_inc)  * strike_inc
f_px(p) => str.tostring(p, "#.##")
// strike n steps ITM (n>0) / OTM (n<0) / ATM (0) relative to the entry level, side-aware
f_strike_n(e, isl, n) =>
    float k = na
    if n == 0
        k := f_round(e)
    else if n > 0
        k := isl ? f_floor(e) - (n - 1) * strike_inc : f_ceil(e) + (n - 1) * strike_inc
    else
        k := isl ? f_ceil(e) + (-n - 1) * strike_inc : f_floor(e) - (-n - 1) * strike_inc
    k
int sel_n = strike_sel == "2 ITM" ? 2 : strike_sel == "1 ITM" ? 1 : strike_sel == "1 OTM" ? -1 : strike_sel == "2 OTM" ? -2 : 0
// display side: a LIVE trade first, else the structure-aligned side
bool have = or_set and not na(Le) and not na(Se)
int dside = in_long ? 1 : in_short ? -1 : traded_l ? 1 : traded_s ? -1 : gate_off ? 0 : eff_up ? 1 : eff_down ? -1 : 0   // F58: gate off ⇒ no forced bias when flat (wait for the actual breakout side)
bool islong = dside == 1
bool shc = dside != 0 and have
float e_  = islong ? Le : Se
float s_  = islong ? l_stop_now : s_stop_now
float t1_ = islong ? Lt1 : St1
float k_naked = shc ? f_strike_n(e_, islong, sel_n) : na          // the chosen BUY strike
float k_itm2  = shc ? f_strike_n(e_, islong,  2) : na             // ladder for the dashboard
float k_itm1  = shc ? f_strike_n(e_, islong,  1) : na
float k_atm   = shc ? f_strike_n(e_, islong,  0) : na
float k_otm1  = shc ? f_strike_n(e_, islong, -1) : na
float k_otm2  = shc ? f_strike_n(e_, islong, -2) : na
float ds_s = shc ? f_round(t1_) : na                              // debit-spread short leg = cap @ TP1
float cs_s = shc ? f_round(s_)  : na                              // credit-spread short leg = the structure stop
float cs_l = shc ? (islong ? cs_s - spread_w : cs_s + spread_w) : na
string oc = islong ? "C" : "P"                                    // naked / debit side
string cc = islong ? "P" : "C"                                    // credit spread = the OTHER side
bool side_macro = islong ? macro_long_ok : macro_short_ok
bool gated  = macro_allow and side_macro and local_ok
bool filled = in_long or in_short
string dir_txt = dside == 1 ? "LONG" : dside == -1 ? "SHORT" : "—"
// expiries: 0DTE today · furthest allowed hold = +max_dte TRADING days
f_addtd(t0, n) =>
    int t1 = t0
    int added = 0
    while added < n
        t1 += 86400000
        int dw = dayofweek(t1, sess_tz)
        if dw != dayofweek.saturday and dw != dayofweek.sunday
            added += 1
    t1
int t_max = f_addtd(time, max_dte)
string exp_txt = "0DTE " + str.tostring(month(time)) + "/" + str.tostring(dayofmonth(time)) +
     "  ·  max hold " + str.tostring(max_dte) + "DTE " + str.tostring(month(t_max)) + "/" + str.tostring(dayofmonth(t_max))
// ── per-side strikes for the LONG|SHORT dashboard ──
float kNl = have ? f_strike_n(Le, true,  sel_n) : na     // naked-buy strikes
float kNs = have ? f_strike_n(Se, false, sel_n) : na
float dsl = have ? f_round(Lt1) : na                     // debit-spread short legs (cap @ TP1)
float dss = have ? f_round(St1) : na
float csl = have ? f_round(l_stop_now) : na              // credit-spread short legs (@ the stop)
float css = have ? f_round(s_stop_now) : na
float cll = csl - spread_w
float cls = css + spread_w
// ── rough premium estimate (Black-Scholes; NO chain access in Pine — sizing intuition only) ──
f_ncdf(x) =>
    float tt = 1.0 / (1.0 + 0.2316419 * math.abs(x))
    float dn = 0.3989423 * math.exp(-x * x / 2.0)
    float pp = dn * tt * (0.3193815 + tt * (-0.3565638 + tt * (1.781478 + tt * (-1.821256 + tt * 1.330274))))
    x >= 0 ? 1.0 - pp : pp
f_bs(S, K, isCall) =>
    float v = math.max(iv_pct, 1.0) / 100.0
    float T = (math.max(est_dte, 0) + 0.5) / 252.0
    float d1 = (math.log(S / K) + 0.5 * v * v * T) / (v * math.sqrt(T))
    float d2 = d1 - v * math.sqrt(T)
    isCall ? S * f_ncdf(d1) - K * f_ncdf(d2) : K * f_ncdf(-d2) - S * f_ncdf(-d1)
f_strat(isl, kN, ds, cs, cl) =>
    strat_sel == "Naked buy" ? "Buy " + (isl ? "Call " : "Put ") + f_px(kN) :
     strat_sel == "Debit spread" ? "Debit " + (isl ? "Call " : "Put ") + f_px(kN) + "/" + f_px(ds) :
     "Credit " + (isl ? "Put " : "Call ") + f_px(cs) + "/" + f_px(cl)
f_cost(isl, kN, ds, cs, cl) =>
    string out = "@ broker"
    if est_on and not na(kN)
        float c = strat_sel == "Naked buy" ? f_bs(close, kN, isl) :
             strat_sel == "Debit spread" ? f_bs(close, kN, isl) - f_bs(close, ds, isl) :
             f_bs(close, cs, not isl) - f_bs(close, cl, not isl)
        out := (strat_sel == "Credit spread" ? "~ +$" : "~ $") + str.tostring(math.max(c, 0) * 100, "#")
    out
f_grade(trendok, gateok, capok) => not trendok ? "—" : gateok and capok and regime == "A" ? "A+" : gateok and capok ? "A" : gateok ? "B" : "C"
string st = not sym_ok ? "⚠ use SPY or QQQ (scope for now)" :
     tf_s > 1800 ? "use a 5m / 15m chart" :
     not have ? "OR forming…" :
     filled ? "IN TRADE — exit when trail breaks" :
     (traded_l or traded_s) ? "done for today (signal used)" :
     not wkday ? "off-session" :
     not window ? "window closed — no entry today" :
     dside == 0 ? (gate_off ? "waiting: no breakout yet" : use_struct ? "waiting: no HH/HL structure" : "waiting: trend flat") :
     not gated ? "blocked: regime " + regime + (not side_macro ? " + SPY stand-down" : "") :
     not (islong ? cap_long_ok : cap_short_ok) ? "EXT ⚠ beyond VWAP cap — stand down" :
     "ARMED — fires on a touch of " + f_px(e_)

// ───────────────────────── VISUALS ─────────────────────────
plot(show_levels and or_set ? or_high : na, "OR high", color=color.new(color.aqua, 70),   style=plot.style_linebr)
plot(show_levels and or_set ? or_low  : na, "OR low",  color=color.new(color.orange, 70), style=plot.style_linebr)
plot(show_levels and or_set and not na(or_mid) ? or_mid : na, "OR mid (bias)", color=(ormid_bias ? (or_bull ? color.new(color.lime, 25) : color.new(color.red, 25)) : color.new(color.gray, 40)), style=plot.style_linebr, linewidth=1)
plot(show_levels and l_live ? Le : na, "Long entry",  color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(show_levels and s_live ? Se : na, "Short entry", color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(show_levels and l_live ? l_stop_now : na, "Long stop",  color=color.new(color.red, 25),  style=plot.style_linebr)
plot(show_levels and s_live ? s_stop_now : na, "Short stop", color=color.new(color.red, 25),  style=plot.style_linebr)
plot(show_levels and l_live ? Lt1 : na, "Long TP1 (debit cap)",  color=color.new(color.green, 10), style=plot.style_linebr)
plot(show_levels and s_live ? St1 : na, "Short TP1 (debit cap)", color=color.new(color.green, 10), style=plot.style_linebr)
plot(show_levels and l_live ? Lt2 : na, "Long TP2",  color=color.new(color.green, 45), style=plot.style_linebr)
plot(show_levels and s_live ? St2 : na, "Short TP2", color=color.new(color.green, 45), style=plot.style_linebr)
// markers anchored AT the entry level / exit price (NOT the bar high/low — that floated them
// off the lines and stacked CALL/PUT visually). Le/Se = the breakout entry the option translates.
if long_fire
    label.new(bar_index, Le, "CALL", yloc=yloc.price, style=label.style_triangleup,   color=color.new(color.lime, 0), textcolor=color.white, size=size.tiny)
if short_fire
    label.new(bar_index, Se, "PUT",  yloc=yloc.price, style=label.style_triangledown, color=color.new(color.red, 0),  textcolor=color.white, size=size.tiny)
if long_skip
    label.new(bar_index, Le, "EXT", yloc=yloc.price, style=label.style_xcross, color=color.new(color.gray, 0), textcolor=color.gray, size=size.tiny)
if short_skip
    label.new(bar_index, Se, "EXT", yloc=yloc.price, style=label.style_xcross, color=color.new(color.gray, 0), textcolor=color.gray, size=size.tiny)
if exit_l
    label.new(bar_index, close, "EXIT", yloc=yloc.price, style=label.style_square, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)
if exit_s
    label.new(bar_index, close, "EXIT", yloc=yloc.price, style=label.style_square, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)
bgcolor(macro_en and regime == "D" ? color.new(color.red, 90) : na)
f_setlbl(lbl, cond, price, txt, col) =>
    label out = lbl
    if cond and not na(price)
        if na(out)
            out := label.new(bar_index + 2, price, txt, style=label.style_label_left, color=col, textcolor=color.white, size=size.small)
        label.set_xy(out, bar_index + 2, price)
        label.set_text(out, txt)
        label.set_color(out, col)
    else if not na(out)
        label.delete(out)
        out := na
    out
var label lbl_Le = na
var label lbl_Ls = na
var label lbl_Lt = na
var label lbl_Se = na
var label lbl_Ss = na
var label lbl_St = na
if barstate.islast and show_line_labels
    lbl_Le := f_setlbl(lbl_Le, l_live, Le, "▲ ENTRY " + str.tostring(Le, format.mintick), color.new(color.yellow, 0))
    lbl_Ls := f_setlbl(lbl_Ls, l_live, l_stop_now, (in_long ? "TRAIL " : "STOP ") + str.tostring(l_stop_now, format.mintick), color.new(color.red, 0))
    lbl_Lt := f_setlbl(lbl_Lt, l_live, Lt1, "TP1 " + str.tostring(Lt1, format.mintick) + " (debit cap)", color.new(color.green, 0))
    lbl_Se := f_setlbl(lbl_Se, s_live, Se, "▼ ENTRY " + str.tostring(Se, format.mintick), color.new(color.yellow, 0))
    lbl_Ss := f_setlbl(lbl_Ss, s_live, s_stop_now, (in_short ? "TRAIL " : "STOP ") + str.tostring(s_stop_now, format.mintick), color.new(color.red, 0))
    lbl_St := f_setlbl(lbl_St, s_live, St1, "TP1 " + str.tostring(St1, format.mintick) + " (debit cap)", color.new(color.green, 0))
alertcondition(long_fire,  "ORB Options LONG",  "HIGHSTRIKE ORB options: LONG — buy CALL (1-2 ITM) / call debit spread / put credit spread @ structure stop. 0DTE, max 4DTE hold.")
alertcondition(short_fire, "ORB Options SHORT", "HIGHSTRIKE ORB options: SHORT — buy PUT (1-2 ITM) / put debit spread / call credit spread @ structure stop. 0DTE, max 4DTE hold.")
alertcondition(exit_l or exit_s, "ORB Options EXIT", "HIGHSTRIKE ORB options: EXIT — underlying broke the trail; close the option/spread.")

// ───────────────────────── DASHBOARD (options translation only — the STACK chart carries the LONG|SHORT trade plan) ─────────────────────────
f_v(p) => na(p) ? "—" : f_px(p)
var table t = table.new(position.top_right, 3, 7, bgcolor=color.new(color.black, 60), frame_color=color.gray, frame_width=1, border_color=color.new(color.gray, 70), border_width=1)
if barstate.islast and show_table
    string dte_lbl = (est_dte == 0 ? "0DTE" : str.tostring(est_dte) + "DTE") + " ≤" + str.tostring(max_dte)
    string sttL = stL == "ARMED" ? "READY TO BUY" : stL
    string sttS = stS == "ARMED" ? "READY TO BUY" : stS
    table.cell(t, 0, 0, "OPTIONS " + syminfo.ticker + (sym_ok ? "" : " ⚠ SPY/QQQ"), text_color=color.yellow, text_size=size.small)
    table.cell(t, 1, 0, "LONG",  text_color=color.lime, text_size=size.small)
    table.cell(t, 2, 0, "SHORT", text_color=color.red,  text_size=size.small)
    table.cell(t, 0, 1, "OPT", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 1, na(kNl) ? "—" : syminfo.ticker + " " + f_px(kNl) + "C | " + dte_lbl, text_color=color.aqua, text_size=size.tiny)
    table.cell(t, 2, 1, na(kNs) ? "—" : syminfo.ticker + " " + f_px(kNs) + "P | " + dte_lbl, text_color=color.aqua, text_size=size.tiny)
    table.cell(t, 0, 2, "STRAT", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 2, na(kNl) ? "—" : f_strat(true, kNl, dsl, csl, cll), text_color=color.teal, text_size=size.tiny)
    table.cell(t, 2, 2, na(kNs) ? "—" : f_strat(false, kNs, dss, css, cls), text_color=color.teal, text_size=size.tiny)
    table.cell(t, 0, 3, "COST", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 3, na(kNl) ? "—" : f_cost(true, kNl, dsl, csl, cll), text_color=color.silver, text_size=size.tiny)
    table.cell(t, 2, 3, na(kNs) ? "—" : f_cost(false, kNs, dss, css, cls), text_color=color.silver, text_size=size.tiny)
    table.cell(t, 0, 4, "STATE", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 4, sttL, text_color=f_stc(stL), text_size=size.tiny)
    table.cell(t, 2, 4, sttS, text_color=f_stc(stS), text_size=size.tiny)
    table.cell(t, 0, 5, "EXP", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 5, exp_txt, text_color=color.gray, text_size=size.tiny)
    table.cell(t, 2, 5, est_on ? "COST ~est IV " + str.tostring(iv_pct, "#") + "% · real @ broker" : "price @ broker", text_color=color.gray, text_size=size.tiny)
    table.cell(t, 0, 6, "DIR·slope", text_color=color.silver, text_size=size.tiny)
    table.cell(t, 1, 6, "S=" + str.tostring(slope_dir, "#.##") + (dir_slp > 0 ? " ▲" : dir_slp < 0 ? " ▼" : " —") + (use_fast_dir ? " (1m)" : ""), text_color=dir_slp > 0 ? color.lime : dir_slp < 0 ? color.red : color.gray, text_size=size.tiny)
    table.cell(t, 2, 6, "Struct" + (st_dir == 1 ? "▲" : st_dir == 2 ? "▼" : "—"), text_color=st_dir == 1 ? color.lime : st_dir == 2 ? color.red : color.gray, text_size=size.tiny)
