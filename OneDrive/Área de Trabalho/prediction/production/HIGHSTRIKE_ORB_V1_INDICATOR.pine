// ═══════════════════════════════════════════════════════════════════
// HIGHSTRIKE ORB V1 — INDICATOR (visual confirmation; mirrors the strategy's signal logic).
// Plots the Opening Range, the breakout long/short signals, trend EMA, macro/local regime,
// and (optional) higher-timeframe trend confirmation. Fires alerts. No orders.
// Signal logic is identical to HIGHSTRIKE_ORB_V1_STRATEGY.pine so what you see == what trades.
// ═══════════════════════════════════════════════════════════════════
//@version=6
indicator("HIGHSTRIKE ORB V1", overlay=true, max_labels_count=300, max_lines_count=300)

// ───────────────────────── INPUTS ─────────────────────────
long_on  = input.bool(true, "LONG signals",  group="Direction", inline="d")
short_on = input.bool(true, "SHORT signals", group="Direction", inline="d")
or_start = input.session("0930-1000", "Opening Range window (ET)", group="ORB")
sess_tz  = input.string("America/New_York", "Timezone", options=["America/New_York","America/Chicago","Europe/London"], group="ORB")
trade_end_hhmm = input.int(1500, "Stop new signals after HHMM (ET)", group="ORB", minval=0, maxval=2359,
                  tooltip="Look ALL DAY (15:00): with stop-entry + EOD-flat, afternoon breakouts are clean too (beats morning-only on exp/PF/win/CI).")
brk_buf_atr = input.float(0.10, "Breakout strength (clear OR by x ATR)", group="ORB", step=0.05, minval=0.0)
auto_tf  = input.bool(true, "Auto config per timeframe", group="ORB",
            tooltip="Breakout buffer <=5m -> 0.0, else 0.25 ATR. Cutoff 15:00 (all day). OFF = manual.")
reentry  = input.bool(false, "Allow re-entry (re-break same day)", group="ORB",
            tooltip="OFF (default) = one signal per side per day (the first break is highest quality). ON = re-arm after price falls back inside the OR, up to N/day. RESEARCH: re-entries DILUTE the edge (QQQ 15m PF 2.11->1.99) — opt-in.")
max_entries = input.int(2, "Max entries per day (re-entry on)", group="ORB", minval=1, maxval=5)
brk_confirm = input.string("Candle close beyond level (full body)", "Breakout fill", group="ORB",
            options=["Candle close beyond level (full body)", "Wick / touch (resting stop)"],
            tooltip="F59: a FILL needs a FULL-BODY close beyond the OR high (long) / OR low (short), not a wick touch. Default close-confirm (validated F59). 'Wick / touch' = the resting-stop entry.")
strong_body = input.float(0.25, "Strong-close: min body / candle range", group="ORB", step=0.05, minval=0.0, maxval=1.0,
            tooltip="Close-confirm only (user rule): the breakout candle must be STRONG — body ≥ this fraction of the full range AND the right colour (bullish long / bearish short). Default 0.25 = validated sweet spot (F59b; rejects dojis/long-wick rejections). Higher (0.4-0.6) cuts trades + lowers edge. 0 = any close beyond the level. The EMA trend gate already requires a clear trend.")
wait_ft = input.bool(true, "Wait for next-candle continuation (2-candle confirm)", group="ORB",
            tooltip="F59c (user rule): don't fire on the breakout candle — WAIT for the NEXT candle to CONTINUE the trend (higher close long / lower close short), then fill. Stops 'fired into a reversal' entries. Validated: improves QQQ/SPY, ~neutral NQ. Default ON.")
trend_ema_f = input.int(21, "Trend EMA fast", group="Trend", minval=2)
trend_ema_s = input.int(50, "Trend EMA slow", group="Trend", minval=5)
gate_off    = input.bool(false, "Off — plain ORB (no trend gate, F58)", group="Trend",
              tooltip="F58 (2026-06-23): honest gap-aware fills show the trend gate adds ~0 net of costs; the live set (STACK/AUTO/OPTIONS) now defaults to plain ORB. This legacy indicator keeps the EMA trend gate ON by default; enable this to match the honest config.")
local_adx_min = input.float(20.0, "Local ADX min (trend)", group="Local Regime", step=1)
local_atr_hi  = input.float(2.5,  "Volatile ATR%",         group="Local Regime", step=0.25)
block_range   = input.bool(true,  "Block signals in RANGE regime", group="Local Regime")
macro_en       = input.bool(true,  "MACRO regime filter ON", group="Macro Regime")
macro_standdown= input.bool(true,  "Macro stand-down vs SPY trend", group="Macro Regime")
spy_sym  = input.symbol("SPY",      "Macro trend ref", group="Macro Regime")
vix_sym  = input.symbol("CBOE:VIX", "Macro vol ref",   group="Macro Regime")
vix_calm = input.float(15.0, "VIX calm",     group="Macro Regime", step=1)
vix_vol  = input.float(25.0, "VIX volatile", group="Macro Regime", step=1)
vix_ext  = input.float(35.0, "VIX extreme",  group="Macro Regime", step=1)
spy_adx_min = input.float(25.0, "Macro ADX min", group="Macro Regime", step=1)
persist_n   = input.int(3, "Regime persistence bars", group="Macro Regime", minval=1)
block_d     = input.bool(true, "Block in REGIME D", group="Macro Regime")
block_b     = input.bool(true, "Block trend in REGIME B", group="Macro Regime")
// MTF confirmation (matches the strategy's mtf_min)
mtf_on   = input.bool(false, "Higher-TF trend confirmation", group="MTF Confirm",
            tooltip="Require N of {1h, 4h, D} to agree with the breakout (EMA50/200 stack). RESEARCH FINDING: this REDUCES expectancy/PF/win on the ORB (it filters out profitable counter-HTF breakouts) — default OFF. Toggle on to experiment.")
mtf_min  = input.int(2, "Min higher-TFs that must agree (0-3)", group="MTF Confirm", minval=0, maxval=3)
sl_buf_atr  = input.float(0.3, "Stop buffer beyond OR x ATR", group="Risk plan", step=0.1)
min_stop_atr= input.float(0.5, "Min stop x ATR", group="Risk plan", step=0.1)
sl_max_atr  = input.float(2.5, "Max stop x ATR", group="Risk plan", step=0.25)
stop_mode = input.string("OR edge", "Stop placement", group="Risk plan", options=["OR edge", "Structure swing (HH/HL)"],
            tooltip="Default 'OR edge' = validated production. 'Structure swing' rests the stop at the last HH/HL swing (research F25b: ~half the risk, higher R, walk-forward-validated on the structure stack) — opt-in.")
struct_lb = input.int(5, "Structure swing lookback (L=R)", group="Risk plan", minval=2)
tp1_rr      = input.float(1.0, "TP1 R", group="Risk plan", step=0.25)
tp2_rr      = input.float(4.0, "TP2 R", group="Risk plan", step=0.25)
exit_mode = input.string("Scale to TP", "Exit", group="Risk plan", options=["Scale to TP", "Trail (ATR chandelier)"],
            tooltip="Default 'Scale to TP' = validated production. 'Trail' rides the runner with an ATR chandelier (research F27b: beats scale on the structure stack) — opt-in.")
trail_atr = input.float(2.0, "Trail x ATR (trail mode)", group="Risk plan", step=0.5, minval=0.5)
show_plan   = input.bool(true, "Show SL / TP1 / TP2 lines", group="Risk plan")
show_line_labels = input.bool(true, "Write ENTRY / SL / TP1 / TP2 on the chart lines", group="Risk plan")
show_panel  = input.bool(true, "Show position-tool panel (boxes + labels)", group="Risk plan",
              tooltip="Draws the pending setup like the TV long/short position tool: green target box + red stop box with TP1/TP2/SL/entry labels and R:R.")
show_mtf    = input.bool(true, "Show 5m + 15m signals (any chart TF)", group="Multi-TF Display",
              tooltip="Pulls the ORB breakout from the 5m and 15m timeframes so you see them on ANY chart, plus a 5m+15m confluence mark. NOTE: these are RAW breakouts (trend filter only, no macro/regime gates) — confluence awareness, not the gated strategy signal.")
show_mtf_lvl= input.bool(true, "Show 5m/15m resting levels", group="Multi-TF Display")
show_dash = input.bool(true, "Show dashboard", group="Display")

// ───────────────────────── CORE ─────────────────────────
atr14 = ta.atr(14)
[dip, dim, adxV] = ta.dmi(14, 14)
atr_pct = close > 0 ? atr14 / close * 100.0 : 0.0
emaF = ta.ema(close, trend_ema_f)
emaS = ta.ema(close, trend_ema_s)
bool trend_up   = close > emaS and emaF > emaS
bool trend_down = close < emaS and emaF < emaS
bool eff_up   = gate_off ? true : trend_up                              // F58: gate off ⇒ plain ORB (no trend filter)
bool eff_down = gate_off ? true : trend_down
int o_now = hour(time, sess_tz) * 60 + minute(time, sess_tz)
bool new_day = ta.change(time("D")) != 0
bool rth = (dayofweek != dayofweek.saturday and dayofweek != dayofweek.sunday)
int tf_s = timeframe.in_seconds()
float eff_brk = auto_tf ? (tf_s <= 300 ? 0.0 : 0.25) : brk_buf_atr
int   eff_cut_hhmm = auto_tf ? 1500 : trade_end_hhmm
int trade_end = (eff_cut_hhmm / 100) * 60 + (eff_cut_hhmm % 100)

// ───────────────────────── MTF trend (1h / 4h / D EMA50>200 stack) ─────────────────────────
f_htf_dir() =>
    e50 = ta.ema(close, 50)
    e200 = ta.ema(close, 200)
    close > e50 and e50 > e200 ? 1 : close < e50 and e50 < e200 ? -1 : 0
h1 = request.security(syminfo.tickerid, "60",  f_htf_dir(), lookahead=barmerge.lookahead_off)
h4 = request.security(syminfo.tickerid, "240", f_htf_dir(), lookahead=barmerge.lookahead_off)
hD = request.security(syminfo.tickerid, "D",   f_htf_dir(), lookahead=barmerge.lookahead_off)
int mtf_up   = (h1 == 1 ? 1 : 0) + (h4 == 1 ? 1 : 0) + (hD == 1 ? 1 : 0)
int mtf_down = (h1 == -1 ? 1 : 0) + (h4 == -1 ? 1 : 0) + (hD == -1 ? 1 : 0)
bool mtf_long_ok  = not mtf_on or mtf_up   >= mtf_min
bool mtf_short_ok = not mtf_on or mtf_down >= mtf_min

// ───────────────────────── MACRO REGIME ─────────────────────────
spy_b() =>
    [_a,_b,sadx] = ta.dmi(14,14)
    [close, ta.ema(close,20), ta.ema(close,50), sadx]
vix_b() => ta.sma(close,5)
[spc, se20, se50, sadx] = request.security(spy_sym, "D", spy_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix5 = request.security(vix_sym, "D", vix_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
bool spy_up = not na(spc) and spc > se20 and se20 > se50
bool spy_dn = not na(spc) and spc < se20 and se20 < se50
bool spy_trend = (spy_up or spy_dn) and not na(sadx) and sadx >= spy_adx_min
string reg_raw = "-"
if not na(vix5)
    reg_raw := vix5 >= vix_ext ? "D" : vix5 >= vix_vol ? "C" : (vix5 < vix_calm and spy_trend) ? "A" : (vix5 < vix_vol and not spy_trend) ? "B" : spy_trend ? "A" : "B"
var int reg_cnt = 0
var string reg_pend = "-"
var string reg_conf = "-"
int need = reg_raw == "D" ? 0 : persist_n
if reg_raw == "D"
    reg_conf := "D"
    reg_pend := "D"
    reg_cnt := need
else if reg_raw == reg_pend
    reg_cnt += 1
    if reg_cnt >= need
        reg_conf := reg_raw
else
    reg_pend := reg_raw
    reg_cnt := 1
string regime = reg_conf != "-" ? reg_conf : reg_raw
bool macro_allow = not macro_en or not ((regime == "D" and block_d) or (regime == "B" and block_b))
bool macro_long_ok  = not macro_en or not macro_standdown or not spy_dn
bool macro_short_ok = not macro_en or not macro_standdown or not spy_up

// ───────────────────────── LOCAL REGIME ─────────────────────────
int local_regime = atr_pct >= local_atr_hi ? 3 : adxV >= local_adx_min ? 1 : 2
bool local_ok = not block_range or local_regime != 2

// ───────────────────────── OPENING RANGE + BREAKOUT ─────────────────────────
bool in_or = not na(time(timeframe.period, or_start, sess_tz))
var float or_high = na
var float or_low  = na
var bool  or_set  = false
if new_day
    or_high := na
    or_low  := na
    or_set  := false
if in_or
    or_high := na(or_high) ? high : math.max(or_high, high)
    or_low  := na(or_low)  ? low  : math.min(or_low,  low)
if not in_or and not na(or_high)
    or_set := true
// resting-stop entry levels + full trade plan frozen at OR close; FILL = price TOUCHES the level
float brk_buf = atr14 * eff_brk
// last confirmed HH/HL swing — for the optional structure-anchored stop (F25b)
float _ph = ta.pivothigh(high, struct_lb, struct_lb)
float _pl = ta.pivotlow(low,  struct_lb, struct_lb)
var float sw_hi = na
var float sw_lo = na
if not na(_ph)
    sw_hi := _ph
if not na(_pl)
    sw_lo := _pl
var float Le = na
var float Ls = na
var float Se = na
var float Ss = na
var bool  traded_l = false
var bool  traded_s = false
var bool  armed_l = true
var bool  armed_s = true
var int   day_n = 0
if new_day
    Le := na
    Ls := na
    Se := na
    Ss := na
    traded_l := false
    traded_s := false
    armed_l := true
    armed_s := true
    day_n := 0
if or_set and na(Le) and not na(or_high) and not na(or_low)
    float aL = (stop_mode == "Structure swing (HH/HL)" and not na(sw_lo)) ? sw_lo : or_low
    float aS = (stop_mode == "Structure swing (HH/HL)" and not na(sw_hi)) ? sw_hi : or_high
    Le := or_high + brk_buf
    Ls := math.min(math.max(aL - atr14 * sl_buf_atr, Le - atr14 * sl_max_atr), Le - atr14 * min_stop_atr)
    Se := or_low  - brk_buf
    Ss := math.max(math.min(aS + atr14 * sl_buf_atr, Se + atr14 * sl_max_atr), Se + atr14 * min_stop_atr)
float Lt1 = Le + (Le - Ls) * tp1_rr
float Lt2 = Le + (Le - Ls) * tp2_rr
float St1 = Se - (Ss - Se) * tp1_rr
float St2 = Se - (Ss - Se) * tp2_rr
bool window = or_set and rth and o_now < trade_end and not na(Le)
bool gate_long  = long_on  and eff_up   and macro_allow and macro_long_ok  and local_ok and mtf_long_ok
bool gate_short = short_on and eff_down  and macro_allow and macro_short_ok and local_ok and mtf_short_ok
// re-entry: re-arm once price falls back inside the OR; cap entries/day. OFF => one signal per side.
if reentry and not na(or_high) and close < or_high
    armed_l := true
if reentry and not na(or_low) and close > or_low
    armed_s := true
bool ok_l = reentry ? (armed_l and day_n < max_entries) : not traded_l
bool ok_s = reentry ? (armed_s and day_n < max_entries) : not traded_s
bool conf_close = brk_confirm == "Candle close beyond level (full body)"          // F59: full-body STRONG close beyond the level
bool body_strong = (high - low) <= 0 or math.abs(close - open) >= strong_body * (high - low)
bool qual_l = close >= Le and close > open and body_strong
bool qual_s = close <= Se and close < open and body_strong
bool brk_l = conf_close ? (wait_ft ? (qual_l[1] and close > close[1]) : qual_l) : high >= Le   // F59c: fire on the next-candle continuation
bool brk_s = conf_close ? (wait_ft ? (qual_s[1] and close < close[1]) : qual_s) : low  <= Se
bool dir_seq = input.bool(true, "Direction sequence (price pushing the trade way)", group="ORB", tooltip="F61: only fire while close>close[1]>close[2] (long) / mirror (short). Graduate on the touch fill, ~neutral on close-confirm. Default ON.")
bool seq_l = not dir_seq or (close > close[1] and close[1] > close[2])
bool seq_s = not dir_seq or (close < close[1] and close[1] < close[2])
bool long_fire  = window and ok_l and gate_long  and brk_l and seq_l
bool short_fire = window and ok_s and gate_short and brk_s and seq_s
if long_fire
    traded_l := true
    armed_l := false
    day_n := day_n + 1
if short_fire
    traded_s := true
    armed_s := false
    day_n := day_n + 1
// keep the plan on screen AFTER the fill too (until stop / TP2 / session end) — for managing the live trade
bool is_trail = exit_mode == "Trail (ATR chandelier)"
var bool in_long  = false
var bool in_short = false
var float lstop = na
var float sstop = na
if new_day
    in_long  := false
    in_short := false
    lstop := na
    sstop := na
if long_fire
    in_long  := true
    lstop := Ls
if short_fire
    in_short := true
    sstop := Ss
if in_long
    if is_trail
        lstop := math.max(lstop, close - trail_atr * atr14)
    if (is_trail ? low <= lstop : (low <= Ls or high >= Lt2))
        in_long  := false
if in_short
    if is_trail
        sstop := math.min(sstop, close + trail_atr * atr14)
    if (is_trail ? high >= sstop : (high >= Ss or low <= St2))
        in_short := false
float l_stop_now = (is_trail and in_long) ? lstop : Ls
float s_stop_now = (is_trail and in_short) ? sstop : Ss
bool l_live = (window and not traded_l) or in_long
bool s_live = (window and not traded_s) or in_short

// ───────────────────────── PLOTS + ALERTS ─────────────────────────
plot(or_set ? or_high : na, "OR high", color=color.new(color.aqua, 55),   style=plot.style_linebr)
plot(or_set ? or_low  : na, "OR low",  color=color.new(color.orange, 55), style=plot.style_linebr)
// RESTING ENTRY LEVELS — where the buy-stop / sell-stop is waiting (visible as a price line)
plot(l_live ? Le : na, "Long entry (buy-stop)",   color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(s_live ? Se : na, "Short entry (sell-stop)", color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
// FULL TRADE PLAN — stop-loss + TP1 + TP2 for the live setup
bool lplan = show_plan and l_live
bool splan = show_plan and s_live
plot(lplan ? l_stop_now : na, "Long SL",   color=color.new(color.red, 15), style=plot.style_linebr, linewidth=2)
plot(lplan and not is_trail ? Lt1 : na, "Long TP1",  color=color.new(color.teal,  20), style=plot.style_linebr)
plot(lplan and not is_trail ? Lt2 : na, "Long TP2",  color=color.new(color.green, 10), style=plot.style_linebr)
plot(splan ? s_stop_now : na, "Short SL",  color=color.new(color.red, 15), style=plot.style_linebr, linewidth=2)
plot(splan and not is_trail ? St1 : na, "Short TP1", color=color.new(color.teal,  20), style=plot.style_linebr)
plot(splan and not is_trail ? St2 : na, "Short TP2", color=color.new(color.green, 10), style=plot.style_linebr)
// WRITE ENTRY / SL / TP on the chart lines (floating labels at the right edge; one reused label per level)
f_setlbl(lbl, cond, price, txt, col) =>
    label out = lbl
    if cond and not na(price)
        if na(out)
            out := label.new(bar_index + 2, price, txt, style=label.style_label_left, color=col, textcolor=color.white, size=size.small)
        label.set_xy(out, bar_index + 2, price)
        label.set_text(out, txt)
        label.set_color(out, col)
    else if not na(out)
        label.delete(out)
        out := na
    out
var label lbl_Le  = na
var label lbl_Ls  = na
var label lbl_Lt1 = na
var label lbl_Lt2 = na
var label lbl_Se  = na
var label lbl_Ss  = na
var label lbl_St1 = na
var label lbl_St2 = na
if barstate.islast and show_line_labels
    string r1 = str.tostring(tp1_rr, "#.#")
    string r2 = str.tostring(tp2_rr, "#.#")
    lbl_Le  := f_setlbl(lbl_Le,  l_live, Le,  "▲ ENTRY " + str.tostring(Le,  format.mintick),                 color.new(color.yellow, 0))
    string lst = is_trail ? "TRAIL STOP " : "SL "
    lbl_Ls  := f_setlbl(lbl_Ls,  lplan,  l_stop_now,  lst + str.tostring(l_stop_now,  format.mintick),         color.new(color.red, 0))
    lbl_Lt1 := f_setlbl(lbl_Lt1, lplan and not is_trail, Lt1, "TP1 " + str.tostring(Lt1, format.mintick) + "  +" + r1 + "R",   color.new(color.teal, 0))
    lbl_Lt2 := f_setlbl(lbl_Lt2, lplan and not is_trail, Lt2, "TP2 " + str.tostring(Lt2, format.mintick) + "  +" + r2 + "R",   color.new(color.green, 0))
    lbl_Se  := f_setlbl(lbl_Se,  s_live, Se,  "▼ ENTRY " + str.tostring(Se,  format.mintick),                 color.new(color.yellow, 0))
    lbl_Ss  := f_setlbl(lbl_Ss,  splan,  s_stop_now,  lst + str.tostring(s_stop_now,  format.mintick),         color.new(color.red, 0))
    lbl_St1 := f_setlbl(lbl_St1, splan and not is_trail, St1, "TP1 " + str.tostring(St1, format.mintick) + "  +" + r1 + "R",   color.new(color.teal, 0))
    lbl_St2 := f_setlbl(lbl_St2, splan and not is_trail, St2, "TP2 " + str.tostring(St2, format.mintick) + "  +" + r2 + "R",   color.new(color.green, 0))
plot(emaS, "EMA slow", color=trend_up ? color.new(color.lime,50) : trend_down ? color.new(color.red,50) : color.new(color.gray,60))
// FILL markers anchored AT the breakout level — a LONG fill sits at/above the OR high (Le = OR high + buffer),
// a SHORT at/below the OR low (Se = OR low − buffer); makes the break-confirmation visible (matches STACK).
if long_fire
    label.new(bar_index, conf_close ? close : Le, "FILL ▲", yloc=yloc.price, style=label.style_label_up,   color=color.new(color.lime, 0), textcolor=color.white, size=size.small)
if short_fire
    label.new(bar_index, conf_close ? close : Se, "FILL ▼", yloc=yloc.price, style=label.style_label_down, color=color.new(color.red, 0),  textcolor=color.white, size=size.small)
bgcolor(macro_en and regime == "D" ? color.new(color.red, 90) : na)
bgcolor(block_range and local_regime == 2 ? color.new(color.gray, 92) : na)
alertcondition(long_fire,  "ORB Long",  "HIGHSTRIKE ORB: LONG breakout confirmed")
alertcondition(short_fire, "ORB Short", "HIGHSTRIKE ORB: SHORT breakout confirmed")
// ARMED pre-alerts — fire the moment a gated setup is ready, BEFORE price touches the trigger
bool arm_l = window and ok_l and gate_long  and (Le - Ls > 0)
bool arm_s = window and ok_s and gate_short and (Ss - Se > 0)
alertcondition(arm_l and not arm_l[1], "ORB ARMED Long",  "HIGHSTRIKE ORB: LONG setup ARMED — buy-stop level live, will fire on the touch")
alertcondition(arm_s and not arm_s[1], "ORB ARMED Short", "HIGHSTRIKE ORB: SHORT setup ARMED — sell-stop level live, will fire on the touch")

// ───────────────────────── MULTI-TF SIGNALS (5m + 15m, on ANY chart TF) ─────────────────────────
// raw OR breakout (trend filter only; no macro/regime — nested security not allowed) pulled per-TF
orb_break() =>
    var float orh = na
    var float orl = na
    var bool  orset = false
    var float lvl_l = na
    var float lvl_s = na
    var bool  ldone = false
    var bool  sdone = false
    nd = ta.change(time("D")) != 0
    if nd
        orh := na
        orl := na
        orset := false
        lvl_l := na
        lvl_s := na
        ldone := false
        sdone := false
    inor = not na(time(timeframe.period, or_start, sess_tz))
    if inor
        orh := na(orh) ? high : math.max(orh, high)
        orl := na(orl) ? low  : math.min(orl, low)
    if not inor and not na(orh)
        orset := true
    a  = ta.atr(14)
    ef = ta.ema(close, 21)
    es = ta.ema(close, 50)
    tup = close > es and ef > es
    tdn = close < es and ef < es
    onow2 = hour(time, sess_tz) * 60 + minute(time, sess_tz)
    tfs = timeframe.in_seconds()
    tod2 = 900                                   // look all day (15:00 ET)
    buf = a * (tfs <= 300 ? 0.0 : 0.25)
    if orset and na(lvl_l) and not na(orh)
        lvl_l := orh + buf
        lvl_s := orl - buf
    aft = orset and onow2 < tod2 and not na(lvl_l)
    lsg = aft and not ldone and high >= lvl_l and tup
    ssg = aft and not sdone and low  <= lvl_s and tdn
    if lsg
        ldone := true
    if ssg
        sdone := true
    [lsg ? 1 : 0, ssg ? 1 : 0, (aft and not ldone ? lvl_l : na), (aft and not sdone ? lvl_s : na)]

[m5l, m5s, m5lL, m5sL]     = request.security(syminfo.tickerid, "5",  orb_break(), lookahead=barmerge.lookahead_off)
[m15l, m15s, m15lL, m15sL] = request.security(syminfo.tickerid, "15", orb_break(), lookahead=barmerge.lookahead_off)
plot(show_mtf and show_mtf_lvl ? m5lL  : na, "MTF 5m long lvl",   color=color.new(color.lime, 35), style=plot.style_linebr)
plot(show_mtf and show_mtf_lvl ? m5sL  : na, "MTF 5m short lvl",  color=color.new(color.red, 35),  style=plot.style_linebr)
plot(show_mtf and show_mtf_lvl ? m15lL : na, "MTF 15m long lvl",  color=color.new(color.lime, 70), style=plot.style_linebr)
plot(show_mtf and show_mtf_lvl ? m15sL : na, "MTF 15m short lvl", color=color.new(color.red, 70),  style=plot.style_linebr)
plotshape(show_mtf and m5l  == 1, "5m long",  shape.triangleup,   location.belowbar, color.new(color.teal, 20),   text="5m",  textcolor=color.teal,   size=size.tiny)
plotshape(show_mtf and m5s  == 1, "5m short", shape.triangledown, location.abovebar, color.new(color.maroon, 20), text="5m",  textcolor=color.maroon, size=size.tiny)
plotshape(show_mtf and m15l == 1, "15m long", shape.triangleup,   location.belowbar, color.new(color.lime, 0),    text="15m", textcolor=color.lime,   size=size.tiny)
plotshape(show_mtf and m15s == 1, "15m short",shape.triangledown, location.abovebar, color.new(color.red, 0),     text="15m", textcolor=color.red,    size=size.tiny)
var bool m5ld = false
var bool m5sd = false
var bool m15ld = false
var bool m15sd = false
var bool lcdone = false
var bool scdone = false
if ta.change(time("D")) != 0
    m5ld := false
    m5sd := false
    m15ld := false
    m15sd := false
    lcdone := false
    scdone := false
if m5l == 1
    m5ld := true
if m5s == 1
    m5sd := true
if m15l == 1
    m15ld := true
if m15s == 1
    m15sd := true
bool Lconf = show_mtf and not lcdone and m5ld and m15ld
bool Sconf = show_mtf and not scdone and m5sd and m15sd
if Lconf
    lcdone := true
if Sconf
    scdone := true
plotshape(Lconf, "5m+15m LONG confluence",  shape.labelup,   location.belowbar, color.new(color.lime, 0), text="5+15↑", textcolor=color.black, size=size.small)
plotshape(Sconf, "5m+15m SHORT confluence", shape.labeldown, location.abovebar, color.new(color.red, 0),  text="5+15↓", textcolor=color.white, size=size.small)
alertcondition(Lconf, "5m+15m LONG confluence",  "HIGHSTRIKE ORB: 5m+15m LONG confluence")
alertcondition(Sconf, "5m+15m SHORT confluence", "HIGHSTRIKE ORB: 5m+15m SHORT confluence")

var table dash = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 70), frame_color=color.gray, frame_width=1)
if barstate.islast and show_dash
    table.cell(dash,0,0,"HIGHSTRIKE ORB", text_color=color.yellow, text_size=size.small)
    table.cell(dash,1,0, str.tostring(syminfo.ticker)+" "+timeframe.period, text_color=color.silver, text_size=size.small)
    table.cell(dash,0,1,"Regime", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,1, regime+(spy_up?" SPY↑":spy_dn?" SPY↓":""), text_color=regime=="A"?color.lime:regime=="D"?color.red:color.aqua, text_size=size.tiny)
    table.cell(dash,0,2,"Trend", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,2, trend_up?"UP":trend_down?"DOWN":"flat", text_color=trend_up?color.lime:trend_down?color.red:color.gray, text_size=size.tiny)
    table.cell(dash,0,3,"Local", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,3, local_regime==1?"TREND":local_regime==2?"RANGE":"VOL", text_color=local_ok?color.lime:color.orange, text_size=size.tiny)
    table.cell(dash,0,4,"HTF trend", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,4, "↑"+str.tostring(mtf_up)+" ↓"+str.tostring(mtf_down)+"/3  | 5m"+(m5ld?"↑":m5sd?"↓":"-")+" 15m"+(m15ld?"↑":m15sd?"↓":"-"), text_color=color.aqua, text_size=size.tiny)
    table.cell(dash,0,5,"OR", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,5, or_set?(str.tostring(or_low,"#.#")+"/"+str.tostring(or_high,"#.#")):"forming", text_color=color.aqua, text_size=size.tiny)

// ───────────────────────── POSITION-TOOL PANEL (labeled SL/TP boxes, like the TV long/short tool) ─────────────────────────
bool panel_long  = show_panel and show_plan and window and not traded_l and gate_long
bool panel_short = show_panel and show_plan and window and not traded_s and gate_short
var box   pbx_g = na
var box   pbx_r = na
var label plb_e  = na
var label plb_t1 = na
var label plb_t2 = na
var label plb_sl = na
if barstate.islast
    bool any = panel_long or panel_short
    float pe  = panel_long ? Le  : panel_short ? Se  : na
    float psl = panel_long ? Ls  : panel_short ? Ss  : na
    float pt1 = panel_long ? Lt1 : panel_short ? St1 : na
    float pt2 = panel_long ? Lt2 : panel_short ? St2 : na
    string etx = panel_long ? "Stop-entry BUY" : panel_short ? "Stop-entry SELL" : ""
    int x1 = bar_index - 5
    int x2 = bar_index + 12
    if any and not na(pe) and not na(psl) and not na(pt2)
        float rr = math.abs(pe - psl) > 0 ? math.abs(pt2 - pe) / math.abs(pe - psl) : 0.0
        if na(pbx_g)
            pbx_g  := box.new(x1, pe, x2, pe, border_color=color.new(color.teal, 50), bgcolor=color.new(color.teal, 88))
            pbx_r  := box.new(x1, pe, x2, pe, border_color=color.new(color.red, 50),  bgcolor=color.new(color.red, 90))
            plb_e  := label.new(x2, pe,  "", style=label.style_label_left, color=color.new(color.gray, 20), textcolor=color.white, size=size.small)
            plb_t1 := label.new(x2, pt1, "", style=label.style_label_left, color=color.new(color.teal, 10), textcolor=color.white, size=size.small)
            plb_t2 := label.new(x2, pt2, "", style=label.style_label_left, color=color.new(color.green, 0), textcolor=color.white, size=size.small)
            plb_sl := label.new(x2, psl, "", style=label.style_label_left, color=color.new(color.red, 0),   textcolor=color.white, size=size.small)
        box.set_top(pbx_g, math.max(pe, pt2))
        box.set_bottom(pbx_g, math.min(pe, pt2))
        box.set_left(pbx_g, x1)
        box.set_right(pbx_g, x2)
        box.set_top(pbx_r, math.max(pe, psl))
        box.set_bottom(pbx_r, math.min(pe, psl))
        box.set_left(pbx_r, x1)
        box.set_right(pbx_r, x2)
        label.set_xy(plb_e, x2, pe)
        label.set_text(plb_e, etx + "  " + str.tostring(pe, format.mintick))
        label.set_xy(plb_t1, x2, pt1)
        label.set_text(plb_t1, "TP1  " + str.tostring(pt1, format.mintick) + "  +" + str.tostring(tp1_rr, "#.#") + "R")
        label.set_xy(plb_t2, x2, pt2)
        label.set_text(plb_t2, "TP2  " + str.tostring(pt2, format.mintick) + "  +" + str.tostring(tp2_rr, "#.#") + "R   |  R:R " + str.tostring(rr, "#.##"))
        label.set_xy(plb_sl, x2, psl)
        label.set_text(plb_sl, "SL  " + str.tostring(psl, format.mintick) + "  -1R")
    if not any and not na(pbx_g)
        box.delete(pbx_g)
        box.delete(pbx_r)
        label.delete(plb_e)
        label.delete(plb_t1)
        label.delete(plb_t2)
        label.delete(plb_sl)
        pbx_g  := na
        pbx_r  := na
        plb_e  := na
        plb_t1 := na
        plb_t2 := na
        plb_sl := na
