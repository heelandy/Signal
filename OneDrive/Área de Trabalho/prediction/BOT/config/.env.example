# ============================================================================
# HIGHSTRIKE BOT — credentials & paths.  Copy this file to  BOT/config/.env
# and fill in the values.  .env is git-ignored; .env.example is committed.
# ============================================================================

# --- Databento: historical + live market data -------------------------------
# Portal -> Settings -> API keys.  Key looks like  db-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
DATABENTO_API_KEY=db-PUT_YOUR_KEY_HERE

# --- Alpaca: equity + options execution (paper first) -----------------------
# https://app.alpaca.markets  -> Paper account -> Generate API keys
ALPACA_API_KEY_ID=PUT_YOUR_KEY_ID_HERE
ALPACA_API_SECRET_KEY=PUT_YOUR_SECRET_HERE
# true  = paper account (fake money).   Going live is a SEPARATE locked gate.
ALPACA_PAPER=true

# --- Futures broker (later phase: NQ/ES/GC) ---------------------------------
# Tradovate or IBKR.  Left blank for now — equity/options path is built first.
FUTURES_BROKER=
FUTURES_API_KEY=
FUTURES_API_SECRET=

# --- Local Databento batch downloads already on disk ------------------------
# These are read directly (duckdb reads .zst) — NO API key needed for them.
DATABENTO_OPRA_DIR=D:/OPRA-20260627-5VQCWWD67U
DATABENTO_XNAS_DIR=D:/XNAS-20260627-9JFGFERR4Y
# SPY equity MBO batch — drop the downloaded folder here, then it just runs:
#   python -m bot.orderflow.run_symbol SPY 2026-07-01
DATABENTO_XNAS_SPY_DIR=D:/XNAS-SPY-REPLACE_WHEN_DOWNLOADED

# --- TradingView webhook shared secret --------------------------------------
# Put the SAME value in the AUTO Pine "Extra params" as  "token":"<value>"  so the bot can
# authenticate inbound alerts. Generate any long random string.
WEBHOOK_TOKEN=changeme-pick-a-long-random-string

# --- Execution mode: replay | paper | live ----------------------------------
# live is HARD-LOCKED in code until the readiness gate passes (see BUILD_PLAN.md).
BOT_MODE=replay
