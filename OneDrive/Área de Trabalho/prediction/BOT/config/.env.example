# ============================================================================
# HIGHSTRIKE BOT — credentials & paths.  Copy this file to  BOT/config/.env
# and fill in the values.  .env is git-ignored; .env.example is committed.
# ============================================================================

# --- Databento: historical + LIVE real-time market data ---------------------
# Portal -> Settings -> API keys.  Key looks like  db-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The SAME key drives the LIVE gateway (real-time futures price for NQ/GC, used automatically once set)
# IF your subscription has a live entitlement for the dataset (GLBX.MDP3 futures / XNAS.ITCH equities).
# No live entitlement -> the live call self-disables and the router falls back to Yahoo. No code change.
DATABENTO_API_KEY=db-PUT_YOUR_KEY_HERE

# --- Alpaca: equity + options execution (paper first) -----------------------
# https://app.alpaca.markets  -> Paper account -> Generate API keys
ALPACA_API_KEY_ID=PUT_YOUR_KEY_ID_HERE
ALPACA_API_SECRET_KEY=PUT_YOUR_SECRET_HERE
# true  = paper account (fake money).   Going live is a SEPARATE locked gate.
ALPACA_PAPER=true

# --- Futures broker (later phase: NQ/ES/GC) ---------------------------------
# Tradovate or IBKR.  Left blank for now — equity/options path is built first.
FUTURES_BROKER=
FUTURES_API_KEY=
FUTURES_API_SECRET=

# --- Local Databento batch downloads already on disk ------------------------
# These are read directly (duckdb reads .zst) — NO API key needed for them.
DATABENTO_OPRA_DIR=D:/OPRA-20260627-5VQCWWD67U
DATABENTO_XNAS_DIR=D:/XNAS-20260627-9JFGFERR4Y
# SPY equity MBO batch — drop the downloaded folder here, then it just runs:
#   python -m bot.orderflow.run_symbol SPY 2026-07-01
DATABENTO_XNAS_SPY_DIR=D:/XNAS-SPY-REPLACE_WHEN_DOWNLOADED

# --- Webull OpenAPI: extra market-data provider (optional) -------------------
# Official API (NOT the unofficial package).  pip install webull-openapi-python-sdk
#
# WHEN YOU GET YOUR PERSONAL (PRODUCTION) KEYS — 3 steps, no code changes:
#   1. developer.webull.com -> create an app -> copy your App Key + App Secret.
#   2. Paste them below and set  WEBULL_ENDPOINT=api.webull.com  (production).
#   3. (optional) put webull first in PROVIDER_ORDER to make it your primary equity feed.
# Then open the dashboard -> "Data Sources" -> TEST CONNECTIONS: webull should go green for QQQ/SPY.
#
# NOTE on the TEST/UAT sandbox: those keys only serve AAPL and use
#   WEBULL_ENDPOINT=us-openapi-alb.uat.webullbroker.com  (NOT api.webull.com).
# # FUTURES: Webull DOES serve futures (NQmain/ESmain/GCmain via futures_market_data) but needs a
# # US-FUTURES market-data ENTITLEMENT on the app (401 Insufficient permission until enabled in the portal).
# # Once enabled, futures auto-route to Webull; until then they fall back to Yahoo/Databento.
# Covers US equities/ETFs by default — NOT futures (NQ/GC stay on Yahoo/Databento). Region: us|hk|jp.
WEBULL_APP_KEY=PUT_YOUR_APP_KEY_HERE
WEBULL_APP_SECRET=PUT_YOUR_APP_SECRET_HERE
WEBULL_REGION=us
WEBULL_ENDPOINT=api.webull.com

# --- TradeStation Web API v3: extra market-data provider (equities + FUTURES) -
# Official REST API (api.tradestation.com/docs). Covers US equities AND futures (NQ/ES/GC) — a
# redundant fallback that, unlike Webull, can also serve your futures.
#
# WHEN YOU GET YOUR KEYS — one-time OAuth (it uses refresh tokens, not just key/secret):
#   1. api.tradestation.com -> create an app -> copy Client ID (API key) + Client Secret;
#      set a redirect URI and request scopes incl.  MarketData  and  offline_access.
#   2. Do the auth-code flow ONCE (browser login) to get a long-lived REFRESH TOKEN.
#   3. Paste all three below. TRADESTATION_ENV=live (market data) or sim (paper).
# Then dashboard -> "Data Sources" -> TEST CONNECTIONS to confirm it authenticates.
TRADESTATION_API_KEY=PUT_YOUR_CLIENT_ID_HERE
TRADESTATION_API_SECRET=PUT_YOUR_CLIENT_SECRET_HERE
TRADESTATION_REFRESH_TOKEN=PUT_YOUR_REFRESH_TOKEN_HERE
TRADESTATION_ENV=live

# --- Data-provider priority (optional) --------------------------------------
# Comma-separated order the router tries for bars. Blank = alpaca,yahoo,webull,tradingview.
# To make Webull primary for equities once you have prod keys:  webull,alpaca,yahoo
PROVIDER_ORDER=

# --- TradingView webhook shared secret --------------------------------------
# Put the SAME value in the AUTO Pine "Extra params" as  "token":"<value>"  so the bot can
# authenticate inbound alerts. Generate any long random string.
WEBHOOK_TOKEN=changeme-pick-a-long-random-string

# --- Execution mode: replay | paper | live ----------------------------------
# live is HARD-LOCKED in code until the readiness gate passes (see BUILD_PLAN.md).
BOT_MODE=replay
