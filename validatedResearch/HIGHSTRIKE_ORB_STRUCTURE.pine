// ═══════════════════════════════════════════════════════════════════
// HIGHSTRIKE ORB — STRUCTURE STACK  (RESEARCH / CANDIDATE — not the frozen production set)
// The walk-forward-validated 5m upgrade (research Findings 20 + 21), built on the V1 ORB core:
//   • TREND GATE is TF-ADAPTIVE — on <=5m it uses the HH/HL swing-STRUCTURE state (st_state) instead of
//     the EMA-21/50 stack (F20: structure beats EMA on 5m, NEUTRAL on 15m); on >=15m it falls back to EMA.
//   • VWAP-EXTENSION CAP (F16, k=2.0) — skips breakouts firing > k*ATR beyond session VWAP, on ALL TFs.
//   • Stacked on 5m (F21) the two are ADDITIVE + walk-forward-confirmed: exp ~2x production, DD cut 2-6x,
//     positive every year on NQ+QQQ+SPY, OOS holds. PF 3.6-5.3 is EARNED (not curve-fit).
// ⚠️ The st_state machine below is PORTED from the Python harness (hs_harness.py). It MUST be reconciled
//    bar-for-bar against the harness (Phase-1 toolchain) before live use — a drift means live != backtest.
// ═══════════════════════════════════════════════════════════════════
//@version=6
indicator("HIGHSTRIKE ORB — STRUCTURE STACK", overlay=true, max_labels_count=300, max_lines_count=300)

// ───────────────────────── INPUTS ─────────────────────────
long_on  = input.bool(true, "LONG signals",  group="Direction", inline="d")
short_on = input.bool(true, "SHORT signals", group="Direction", inline="d")
or_start = input.session("0930-1000", "Opening Range window (ET)", group="ORB")
sess_tz  = input.string("America/New_York", "Timezone", options=["America/New_York","America/Chicago","Europe/London"], group="ORB")
trade_end_hhmm = input.int(1500, "Stop new signals after HHMM (ET)", group="ORB", minval=0, maxval=2359)
brk_buf_atr = input.float(0.10, "Breakout strength (clear OR by x ATR)", group="ORB", step=0.05, minval=0.0)
auto_tf  = input.bool(true, "Auto config per timeframe", group="ORB",
            tooltip="Breakout buffer <=5m -> 0.0, else 0.25 ATR. Cutoff 15:00. OFF = manual.")
allow_reentry = input.bool(false, "Allow re-entry (re-arm after price returns inside OR)", group="ORB",
            tooltip="OFF = one breakout per side per day (the validated default). ON = re-arm a side when price falls back inside the OR; capped by Max entries.")
max_entries  = input.int(2, "Max entries per side / day (re-entry)", group="ORB", minval=1)
// STRUCTURE GATE (the F20 upgrade)
trend_mode = input.string("Auto (structure <=5m / EMA >=15m)", "Trend gate", group="Structure gate",
             options=["Auto (structure <=5m / EMA >=15m)", "Structure (HH/HL)", "EMA trend"],
             tooltip="F20: the HH/HL swing-structure state beats EMA-21/50 on 5m, neutral on 15m. Auto uses structure on <=5m, EMA on >=15m.")
struct_lb  = input.int(5, "Structure pivot lookback (L=R)", group="Structure gate", minval=2,
             tooltip="Harness reconcile baseline = 5. A swing pivot is confirmed this many bars after it forms.")
struct_tol = input.float(0.10, "Structure tolerance %", group="Structure gate", step=0.05,
             tooltip="A new swing must differ from the last by >= this % to update the HH/HL state (matches harness).")
trend_ema_f = input.int(21, "Trend EMA fast (>=15m / EMA mode)", group="Structure gate", minval=2)
trend_ema_s = input.int(50, "Trend EMA slow (>=15m / EMA mode)", group="Structure gate", minval=5)
// VWAP-EXTENSION CAP (the F16 upgrade)
cap_on = input.bool(true, "VWAP-extension cap (skip extended breakouts)", group="VWAP cap",
         tooltip="F16: skip a breakout firing > k*ATR beyond session VWAP (those underperform). Helps both TFs.")
cap_k  = input.float(2.0, "Cap k (xATR beyond VWAP)", group="VWAP cap", step=0.25, minval=0.5)
// REGIME
local_adx_min = input.float(20.0, "Local ADX min (trend)", group="Local Regime", step=1)
local_atr_hi  = input.float(2.5,  "Volatile ATR%",         group="Local Regime", step=0.25)
block_range   = input.bool(true,  "Block signals in RANGE regime", group="Local Regime")
macro_en       = input.bool(true,  "MACRO regime filter ON", group="Macro Regime")
macro_standdown= input.bool(true,  "Macro stand-down vs SPY trend", group="Macro Regime")
spy_sym  = input.symbol("SPY",      "Macro trend ref", group="Macro Regime")
vix_sym  = input.symbol("CBOE:VIX", "Macro vol ref",   group="Macro Regime")
vix_calm = input.float(15.0, "VIX calm",     group="Macro Regime", step=1)
vix_vol  = input.float(25.0, "VIX volatile", group="Macro Regime", step=1)
vix_ext  = input.float(35.0, "VIX extreme",  group="Macro Regime", step=1)
spy_adx_min = input.float(25.0, "Macro ADX min", group="Macro Regime", step=1)
persist_n   = input.int(3, "Regime persistence bars", group="Macro Regime", minval=1)
block_d     = input.bool(true, "Block in REGIME D", group="Macro Regime")
block_b     = input.bool(true, "Block trend in REGIME B", group="Macro Regime")
// RISK PLAN
sl_buf_atr  = input.float(0.3, "Stop buffer beyond OR x ATR", group="Risk plan", step=0.1)
min_stop_atr= input.float(0.5, "Min stop x ATR", group="Risk plan", step=0.1)
sl_max_atr  = input.float(2.5, "Max stop x ATR", group="Risk plan", step=0.25)
tp1_rr      = input.float(1.0, "TP1 R", group="Risk plan", step=0.25)
tp2_rr      = input.float(4.0, "TP2 R", group="Risk plan", step=0.25)
show_plan   = input.bool(true, "Show SL / TP1 / TP2 lines", group="Risk plan")
show_line_labels = input.bool(true, "Write ENTRY / SL / TP1 / TP2 on the chart lines", group="Risk plan")
show_dash = input.bool(true, "Show dashboard", group="Display")

// ───────────────────────── CORE ─────────────────────────
atr14 = ta.atr(14)
[dip, dim, adxV] = ta.dmi(14, 14)
atr_pct = close > 0 ? atr14 / close * 100.0 : 0.0
emaF = ta.ema(close, trend_ema_f)
emaS = ta.ema(close, trend_ema_s)
bool trend_up   = close > emaS and emaF > emaS
bool trend_down = close < emaS and emaF < emaS
float vwap_c = ta.vwap
int o_now = hour(time, sess_tz) * 60 + minute(time, sess_tz)
bool new_day = ta.change(time("D")) != 0
bool rth = (dayofweek != dayofweek.saturday and dayofweek != dayofweek.sunday)
int tf_s = timeframe.in_seconds()
float eff_brk = auto_tf ? (tf_s <= 300 ? 0.0 : 0.25) : brk_buf_atr
int   eff_cut_hhmm = auto_tf ? 1500 : trade_end_hhmm
int trade_end = (eff_cut_hhmm / 100) * 60 + (eff_cut_hhmm % 100)

// ───────────────────────── HH/HL STRUCTURE STATE (port of hs_harness.py) ─────────────────────────
// Pivots (confirmed L=R=struct_lb bars after the swing), last/prev swing levels with a tolerance, then
// st_state: 1 = uptrend (HH & HL), 2 = downtrend (LL & LH), 3 = range, 0 = undefined / just had a CHoCH.
float ph = ta.pivothigh(high, struct_lb, struct_lb)
float pl = ta.pivotlow(low,  struct_lb, struct_lb)
var float ph_last = na
var float ph_prev = na
var float pl_last = na
var float pl_prev = na
var int   st_state = 0
int st_prev = st_state
if not na(ph)
    if na(ph_last) or math.abs(ph - ph_last) / ph_last * 100.0 >= struct_tol
        ph_prev := ph_last
        ph_last := ph
if not na(pl)
    if na(pl_last) or math.abs(pl - pl_last) / pl_last * 100.0 >= struct_tol
        pl_prev := pl_last
        pl_last := pl
bool s_hh = not na(ph_last) and not na(ph_prev) and ph_last > ph_prev
bool s_lh = not na(ph_last) and not na(ph_prev) and ph_last < ph_prev
bool s_hl = not na(pl_last) and not na(pl_prev) and pl_last > pl_prev
bool s_ll = not na(pl_last) and not na(pl_prev) and pl_last < pl_prev
if s_hh and s_hl
    st_state := 1
else if s_ll and s_lh
    st_state := 2
else if (s_hh and s_ll) or (s_hl and s_lh)
    st_state := 3
// CHoCH resets the state to 0 (change of character) — matches the harness machine
if st_prev == 2 and not na(ph_last) and close > ph_last and close[1] <= ph_last
    st_state := 0
if st_prev == 1 and not na(pl_last) and close < pl_last and close[1] >= pl_last
    st_state := 0

// ───────────────────────── TF-ADAPTIVE TREND GATE ─────────────────────────
bool use_struct = trend_mode == "Structure (HH/HL)" or (trend_mode == "Auto (structure <=5m / EMA >=15m)" and tf_s <= 300)
bool eff_up   = use_struct ? (st_state == 1) : trend_up
bool eff_down = use_struct ? (st_state == 2) : trend_down

// ───────────────────────── MACRO REGIME ─────────────────────────
spy_b() =>
    [_a,_b,sadx] = ta.dmi(14,14)
    [close, ta.ema(close,20), ta.ema(close,50), sadx]
vix_b() => ta.sma(close,5)
[spc, se20, se50, sadx] = request.security(spy_sym, "D", spy_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
vix5 = request.security(vix_sym, "D", vix_b(), lookahead=barmerge.lookahead_off, ignore_invalid_symbol=true)
bool spy_up = not na(spc) and spc > se20 and se20 > se50
bool spy_dn = not na(spc) and spc < se20 and se20 < se50
bool spy_trend = (spy_up or spy_dn) and not na(sadx) and sadx >= spy_adx_min
string reg_raw = "-"
if not na(vix5)
    reg_raw := vix5 >= vix_ext ? "D" : vix5 >= vix_vol ? "C" : (vix5 < vix_calm and spy_trend) ? "A" : (vix5 < vix_vol and not spy_trend) ? "B" : spy_trend ? "A" : "B"
var int reg_cnt = 0
var string reg_pend = "-"
var string reg_conf = "-"
int need = reg_raw == "D" ? 0 : persist_n
if reg_raw == "D"
    reg_conf := "D"
    reg_pend := "D"
    reg_cnt := need
else if reg_raw == reg_pend
    reg_cnt += 1
    if reg_cnt >= need
        reg_conf := reg_raw
else
    reg_pend := reg_raw
    reg_cnt := 1
string regime = reg_conf != "-" ? reg_conf : reg_raw
bool macro_allow = not macro_en or not ((regime == "D" and block_d) or (regime == "B" and block_b))
bool macro_long_ok  = not macro_en or not macro_standdown or not spy_dn
bool macro_short_ok = not macro_en or not macro_standdown or not spy_up

// ───────────────────────── LOCAL REGIME ─────────────────────────
int local_regime = atr_pct >= local_atr_hi ? 3 : adxV >= local_adx_min ? 1 : 2
bool local_ok = not block_range or local_regime != 2

// ───────────────────────── OPENING RANGE + LEVELS ─────────────────────────
bool in_or = not na(time(timeframe.period, or_start, sess_tz))
var float or_high = na
var float or_low  = na
var bool  or_set  = false
if new_day
    or_high := na
    or_low  := na
    or_set  := false
if in_or
    or_high := na(or_high) ? high : math.max(or_high, high)
    or_low  := na(or_low)  ? low  : math.min(or_low,  low)
if not in_or and not na(or_high)
    or_set := true
float brk_buf = atr14 * eff_brk
var float Le = na
var float Ls = na
var float Se = na
var float Ss = na
var bool  traded_l = false
var bool  traded_s = false
var int   n_l = 0
var int   n_s = 0
if new_day
    Le := na
    Ls := na
    Se := na
    Ss := na
    traded_l := false
    traded_s := false
    n_l := 0
    n_s := 0
if or_set and na(Le) and not na(or_high) and not na(or_low)
    Le := or_high + brk_buf
    Ls := math.min(math.max(or_low  - atr14 * sl_buf_atr, Le - atr14 * sl_max_atr), Le - atr14 * min_stop_atr)
    Se := or_low  - brk_buf
    Ss := math.max(math.min(or_high + atr14 * sl_buf_atr, Se + atr14 * sl_max_atr), Se + atr14 * min_stop_atr)
float Lt1 = Le + (Le - Ls) * tp1_rr
float Lt2 = Le + (Le - Ls) * tp2_rr
float St1 = Se - (Ss - Se) * tp1_rr
float St2 = Se - (Ss - Se) * tp2_rr

// ───────────────────────── VWAP-EXTENSION CAP ─────────────────────────
float extL = na(Le) ? na : (Le - vwap_c) / atr14
float extS = na(Se) ? na : (vwap_c - Se) / atr14
bool cap_long_ok  = not cap_on or na(extL) or extL <= cap_k
bool cap_short_ok = not cap_on or na(extS) or extS <= cap_k

// ───────────────────────── GATES + FIRING ─────────────────────────
bool window = or_set and rth and o_now < trade_end and not na(Le)
bool gate_long  = long_on  and eff_up   and macro_allow and macro_long_ok  and local_ok
bool gate_short = short_on and eff_down  and macro_allow and macro_short_ok and local_ok
// re-entry (default off): re-arm a side once price falls back inside the OR, until max_entries is hit
if allow_reentry and traded_l and not na(or_high) and close < or_high and n_l < max_entries
    traded_l := false
if allow_reentry and traded_s and not na(or_low) and close > or_low and n_s < max_entries
    traded_s := false
// gated breakout occurs on the first touch; the cap decides taken vs skipped — either way the day is consumed
bool sig_l = window and not traded_l and gate_long  and high >= Le
bool sig_s = window and not traded_s and gate_short and low  <= Se
bool long_fire  = sig_l and cap_long_ok
bool short_fire = sig_s and cap_short_ok
bool long_skip  = sig_l and not cap_long_ok      // breakout valid but capped (too extended from VWAP)
bool short_skip = sig_s and not cap_short_ok
if sig_l
    traded_l := true
    n_l += 1
if sig_s
    traded_s := true
    n_s += 1
// keep the plan on screen after the fill (until SL / TP2 / session end)
var bool in_long  = false
var bool in_short = false
if new_day
    in_long  := false
    in_short := false
if long_fire
    in_long  := true
if short_fire
    in_short := true
if in_long and (low <= Ls or high >= Lt2)
    in_long  := false
if in_short and (high >= Ss or low <= St2)
    in_short := false
bool l_live = (window and not traded_l and gate_long) or in_long
bool s_live = (window and not traded_s and gate_short) or in_short

// ───────────────────────── PLOTS + LABELS + ALERTS ─────────────────────────
plot(or_set ? or_high : na, "OR high", color=color.new(color.aqua, 55),   style=plot.style_linebr)
plot(or_set ? or_low  : na, "OR low",  color=color.new(color.orange, 55), style=plot.style_linebr)
plot(l_live ? Le : na, "Long entry",   color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
plot(s_live ? Se : na, "Short entry",  color=color.new(color.yellow, 0), style=plot.style_linebr, linewidth=2)
bool lplan = show_plan and l_live
bool splan = show_plan and s_live
plot(lplan ? Ls  : na, "Long SL",   color=color.new(color.red,   25), style=plot.style_linebr)
plot(lplan ? Lt1 : na, "Long TP1",  color=color.new(color.teal,  20), style=plot.style_linebr)
plot(lplan ? Lt2 : na, "Long TP2",  color=color.new(color.green, 10), style=plot.style_linebr)
plot(splan ? Ss  : na, "Short SL",  color=color.new(color.red,   25), style=plot.style_linebr)
plot(splan ? St1 : na, "Short TP1", color=color.new(color.teal,  20), style=plot.style_linebr)
plot(splan ? St2 : na, "Short TP2", color=color.new(color.green, 10), style=plot.style_linebr)
plotshape(long_fire,  "Long fill",  shape.triangleup,   location.belowbar, color.new(color.lime, 0), text="FILL", textcolor=color.white, size=size.small)
plotshape(short_fire, "Short fill", shape.triangledown, location.abovebar, color.new(color.red, 0),  text="FILL", textcolor=color.white, size=size.small)
plotshape(long_skip,  "Long capped",  shape.xcross, location.belowbar, color.new(color.gray, 0), text="EXT", textcolor=color.gray, size=size.tiny)
plotshape(short_skip, "Short capped", shape.xcross, location.abovebar, color.new(color.gray, 0), text="EXT", textcolor=color.gray, size=size.tiny)
bgcolor(macro_en and regime == "D" ? color.new(color.red, 90) : na)
bgcolor(block_range and local_regime == 2 ? color.new(color.gray, 92) : na)
alertcondition(long_fire,  "STRUCT Long",  "HIGHSTRIKE STRUCTURE: LONG breakout (gated + near-VWAP)")
alertcondition(short_fire, "STRUCT Short", "HIGHSTRIKE STRUCTURE: SHORT breakout (gated + near-VWAP)")

// floating ENTRY/SL/TP labels (same scheme as the production indicator)
f_setlbl(lbl, cond, price, txt, col) =>
    label out = lbl
    if cond and not na(price)
        if na(out)
            out := label.new(bar_index + 2, price, txt, style=label.style_label_left, color=col, textcolor=color.white, size=size.small)
        label.set_xy(out, bar_index + 2, price)
        label.set_text(out, txt)
        label.set_color(out, col)
    else if not na(out)
        label.delete(out)
        out := na
    out
var label lbl_Le  = na
var label lbl_Ls  = na
var label lbl_Lt1 = na
var label lbl_Lt2 = na
var label lbl_Se  = na
var label lbl_Ss  = na
var label lbl_St1 = na
var label lbl_St2 = na
if barstate.islast and show_line_labels
    string r1 = str.tostring(tp1_rr, "#.#")
    string r2 = str.tostring(tp2_rr, "#.#")
    lbl_Le  := f_setlbl(lbl_Le,  l_live, Le,  "▲ ENTRY " + str.tostring(Le,  format.mintick),                 color.new(color.yellow, 0))
    lbl_Ls  := f_setlbl(lbl_Ls,  lplan,  Ls,  "SL "  + str.tostring(Ls,  format.mintick) + "  -1R",            color.new(color.red, 0))
    lbl_Lt1 := f_setlbl(lbl_Lt1, lplan,  Lt1, "TP1 " + str.tostring(Lt1, format.mintick) + "  +" + r1 + "R",   color.new(color.teal, 0))
    lbl_Lt2 := f_setlbl(lbl_Lt2, lplan,  Lt2, "TP2 " + str.tostring(Lt2, format.mintick) + "  +" + r2 + "R",   color.new(color.green, 0))
    lbl_Se  := f_setlbl(lbl_Se,  s_live, Se,  "▼ ENTRY " + str.tostring(Se,  format.mintick),                 color.new(color.yellow, 0))
    lbl_Ss  := f_setlbl(lbl_Ss,  splan,  Ss,  "SL "  + str.tostring(Ss,  format.mintick) + "  -1R",            color.new(color.red, 0))
    lbl_St1 := f_setlbl(lbl_St1, splan,  St1, "TP1 " + str.tostring(St1, format.mintick) + "  +" + r1 + "R",   color.new(color.teal, 0))
    lbl_St2 := f_setlbl(lbl_St2, splan,  St2, "TP2 " + str.tostring(St2, format.mintick) + "  +" + r2 + "R",   color.new(color.green, 0))

// ───────────────────────── DASHBOARD ─────────────────────────
f_q(x) => na(x) ? "—" : x <= cap_k ? "NEAR ✓" : "EXT ⚠"
f_qc(x) => na(x) ? color.gray : x <= cap_k ? color.lime : color.orange
f_st(s) => s == 1 ? "UP (HH+HL)" : s == 2 ? "DOWN (LL+LH)" : s == 3 ? "RANGE" : "—"
var table dash = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 70), frame_color=color.gray, frame_width=1)
if barstate.islast and show_dash
    int dirn = l_live ? 1 : s_live ? -1 : 0
    float e_ = dirn == 1 ? Le : dirn == -1 ? Se : na
    float x_ = dirn == 1 ? extL : dirn == -1 ? extS : na
    bool   filled = in_long or in_short
    bool   armed  = (l_live or s_live) and not filled
    string stat   = filled ? "FILLED ✓" : armed ? "ARMED ◷" : "flat —"
    color  statc  = filled ? color.lime : armed ? color.aqua : color.gray
    string greason = not macro_allow ? ("BLOCK " + regime) : not local_ok ? "RANGE (flat)" : (dirn == 1 and not macro_long_ok) ? "SPY↓ vs long" : (dirn == -1 and not macro_short_ok) ? "SPY↑ vs short" : "clear ✓"
    color  gcol    = greason == "clear ✓" ? color.lime : color.orange
    string plan = dirn == 1 ? ("SL " + str.tostring(Ls, "#.#") + "  T1 " + str.tostring(Lt1, "#.#") + "  T2 " + str.tostring(Lt2, "#.#")) : dirn == -1 ? ("SL " + str.tostring(Ss, "#.#") + "  T1 " + str.tostring(St1, "#.#") + "  T2 " + str.tostring(St2, "#.#")) : "—"
    table.cell(dash,0,0,"HIGHSTRIKE STRUCT", text_color=color.yellow, text_size=size.small)
    table.cell(dash,1,0, str.tostring(syminfo.ticker)+"  "+timeframe.period, text_color=color.silver, text_size=size.small)
    table.cell(dash,0,1,"Regime", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,1, regime+(spy_up?" SPY↑":spy_dn?" SPY↓":""), text_color=regime=="A"?color.lime:regime=="D"?color.red:color.aqua, text_size=size.tiny)
    table.cell(dash,0,2,"Trend gate", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,2, (use_struct?"STRUCT: "+f_st(st_state):"EMA: "+(trend_up?"UP":trend_down?"DOWN":"flat")), text_color=(eff_up?color.lime:eff_down?color.red:color.gray), text_size=size.tiny)
    table.cell(dash,0,3,"Setup", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,3, dirn==1?("LONG "+str.tostring(e_,format.mintick)):dirn==-1?("SHORT "+str.tostring(e_,format.mintick)):"—", text_color=dirn==1?color.lime:dirn==-1?color.red:color.gray, text_size=size.tiny)
    table.cell(dash,0,4,"Status", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,4, stat + (allow_reentry ? ("  (" + str.tostring(dirn==1?n_l:dirn==-1?n_s:0) + "/" + str.tostring(max_entries) + ")") : ""), text_color=statc, text_size=size.tiny)
    table.cell(dash,0,5,"Gated", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,5, greason, text_color=gcol, text_size=size.tiny)
    table.cell(dash,0,6,"VWAP cap", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,6, f_q(x_)+(na(x_)?"":"  "+str.tostring(x_,"#.#")+"x  k="+str.tostring(cap_k,"#.#")), text_color=f_qc(x_), text_size=size.tiny)
    table.cell(dash,0,7,"Plan", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,7, plan, text_color=color.silver, text_size=size.tiny)
    table.cell(dash,0,8,"OR / VWAP", text_color=color.silver, text_size=size.tiny)
    table.cell(dash,1,8, (or_set?(str.tostring(or_low,"#.#")+" / "+str.tostring(or_high,"#.#")):"forming")+"  ·  "+str.tostring(vwap_c,"#.#"), text_color=color.aqua, text_size=size.tiny)
    table.cell(dash,0,9,"NEAR/EXT", text_color=color.gray, text_size=size.tiny)
    table.cell(dash,1,9, "= dist from VWAP (xATR)", text_color=color.gray, text_size=size.tiny)

// ───────────────────────── RECONCILE EXPORT (Phase-1 diff; data-window only, draws nothing) ─────────────────────────
// Toggle ON, then TradingView → right-click chart → "Export chart data" → CSV → `python qa/hs_reconcile.py <csv>`.
// The harness recomputes st_state from the SAME OHLCV and diffs vs these x_* columns. The VERDICT rows are
// x_st_state + x_is_hh/hl/lh/ll (the structure port). x_regime/x_spy_*/x_vix_sma5/x_vwap_sess are informational
// (partial externals → regime may differ, not a port bug). The IDENTICAL machine is in HIGHSTRIKE_ORB_ASIA.pine,
// so this one export validates both. Run on the SAME symbol/TF + a 24/7 (extended-hours) session as the harness.
exp_on = input.bool(false, "Reconcile export (data-window columns)", group="Dev",
         tooltip="Exposes x_* columns in 'Export chart data' to diff this st_state port vs hs_harness.py. Draws nothing on the chart.")
plot(exp_on ? st_state : na,             "x_st_state",   display=display.data_window)
plot(exp_on ? (s_hh ? 1 : 0) : na,       "x_is_hh",      display=display.data_window)
plot(exp_on ? (s_hl ? 1 : 0) : na,       "x_is_hl",      display=display.data_window)
plot(exp_on ? (s_lh ? 1 : 0) : na,       "x_is_lh",      display=display.data_window)
plot(exp_on ? (s_ll ? 1 : 0) : na,       "x_is_ll",      display=display.data_window)
plot(exp_on ? (regime=="A"?1:regime=="B"?2:regime=="C"?3:regime=="D"?4:0) : na, "x_regime", display=display.data_window)
plot(exp_on ? spc : na,                  "x_spy_close",  display=display.data_window)
plot(exp_on ? se20 : na,                 "x_spy_e20",    display=display.data_window)
plot(exp_on ? se50 : na,                 "x_spy_e50",    display=display.data_window)
plot(exp_on ? sadx : na,                 "x_spy_adx",    display=display.data_window)
plot(exp_on ? vix5 : na,                 "x_vix_sma5",   display=display.data_window)
plot(exp_on ? vwap_c : na,               "x_vwap_sess",  display=display.data_window)
plot(exp_on ? (long_fire ? 1 : 0) : na,  "x_long_fire",  display=display.data_window)
plot(exp_on ? (short_fire ? 1 : 0) : na, "x_short_fire", display=display.data_window)
